    GameManager:BlockInfoPortion("barrier_defense_monolith_finished")
    GameManager:BlockInfoPortion("barrier_defense_monolith_first_spawn")
end

function on_game_start()
    -- Send requests and lock npcs...
    RegisterScriptCallback("GUI_on_show", function(name)
        if name ~= "Dialog" then return end
        local npc = mob_trade.GetTalkingNpc()
        if not npc then return end
        PBusied_NPC = npc
        local my_netid = GameManager:GetMySNETID()
        -- Send Lock npcs action
        local payload = { id = GameManager:GetServerIDByLocalID(npc:id()), busy = true, netid = my_netid }
        GameManager:OnICustomScriptAction("dialogs", "remote_configure_npc", serialize_table_simple(payload), false)
        if IIsHost() then return end
        -- Requesting data from host
        GameManager:OnICustomScriptAction("dialogs", "request_trade_data", tostring(my_netid), true)
        GameManager:OnICustomScriptAction("dialogs", "remote_request_generate_tasks", tostring(my_netid), true)
    end)
    -- Send UNLock npcs action
    RegisterScriptCallback("GUI_on_hide", function(name)
        if name ~= "Dialog" or not PBusied_NPC then return end
        local payload = { id = GameManager:GetServerIDByLocalID(PBusied_NPC:id()), busy = false, netid = GameManager:GetMySNETID() }
        GameManager:OnICustomScriptAction("dialogs", "remote_configure_npc", serialize_table_simple(payload), false)
    end)
end