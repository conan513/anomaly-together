    xr_effects.jup_b219_restore_gate = function()
        local yaw = 0
        local spawn_sect = "jup_b219_gate"
        local obj = get_story_object("jup_b219_gate_id")
        if obj then
            local se_obj = alife_create_client(spawn_sect, vector():set(obj:position()), obj:level_vertex_id(),
                obj:game_vertex_id())
            if (se_obj) then
                se_obj:set_yaw(yaw * math.pi / 180)
            end
        end
    end
