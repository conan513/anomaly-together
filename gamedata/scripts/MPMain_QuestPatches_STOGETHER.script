local GameManager = SteamGameManager()
local PlayerManager = GameManager:GetPlayerManager()
local OLDGIVETASKSNOW = task_manager.CRandomTask.give_task
local OLDTASKCHECKTSK = task_objects.CGeneralTask.check_task
local OLDDRXSLGIVE = dialogs.drx_sl_give_sl_task
local OLDDRXCFGIVE = dialogs.drx_sl_give_cf_task
local OLDDRXMCGIVE = dialogs.drx_sl_give_mechanic_task

local original_generate = axr_task_manager.generate_available_tasks
local original_npc_fetc = dialogs.text_npc_has_task
local original_npc_skip = dialogs.npc_skip_task
local original_talking_npc = mob_trade.GetTalkingNpc
local PBusied_NPCS = {}
local PBusied_NPC = nil

function get_busied_npcs()
    return PBusied_NPCS
end

function get_personal_item_count(section)
    if not section then return 0 end
    local count = 0
    db.actor:iterate_inventory(function(_, item)
        if item:section() == section then
            local m_use = IsItem("multiuse", section)
            count = count + (m_use and item:get_remaining_uses() or 1)
        end
    end)
    return count
end

function sync_task_variables(task_id, netid)
    if not (task_id and db.actor) then return end
    local totalvars = {}
    -- Syncing pstore values! Condition to avoid full syncs of big data.
    local actor_st = db.storage[db.actor:id()]
    if actor_st then
        --printf("[TASK-SYNC] Syncing all variables for [%s]...", task_id)
        for var_name, val in pairs(actor_st.pstor) do
            if string.find(tostring(var_name), "^" .. task_id) then
                local mtype = type(val)
                if mtype ~= "function" and mtype ~= "userdata" then
                    totalvars[var_name] = val
                end
            end
        end
    end

    -- Fetch and count sync.
    -- Gen data. Not used for sync in realtime. Only when joined or something another to avoid bug!
    local sec = load_var(db.actor, task_id .. "_fetch")
    if sec then
        --printf("[TASK-SYNC] Syncing fetch variables for [%s]...", task_id)
        totalvars[task_id .. "_fetch"] = sec
        totalvars[task_id .. "_fetch_count"] = load_var(db.actor, task_id .. "_fetch_count")
    end

    -- Syncing default task data
    local task_data = load_var(db.actor, task_id)
    if task_data then
        --printf("[TASK-SYNC] Syncing default variables for [%s]...", task_id)
        -- RF Reciver set position! It's need for client side...
        local target_id = type(task_data) == "table" and tonumber(task_data.target_id or task_data.item_2_id or task_data.squad_id or "65535")
        local se_obj = target_id and target_id ~= 65535 and alife_object(target_id)
        if se_obj then task_data.target_position = { se_obj.position.x, se_obj.position.y, se_obj.position.z } end
        totalvars[task_id] = task_data
    end

    -- Send all data...
    GameManager:OnICustomScriptAction("dialogs", "remote_task_var_sync", serialize_table_simple({ "data", totalvars, true}), false, netid or 0)
end

function GetExistID(a, b, c, d, e)
    if a and alife_object(tonumber(a)) then return tonumber(a) end
    if b and alife_object(tonumber(b)) then return tonumber(b) end
    if c and alife_object(tonumber(c)) then return tonumber(c) end
    if d and alife_object(tonumber(d)) then return tonumber(d) end
    if e and alife_object(tonumber(e)) then return tonumber(e) end
    return 65535
end

function PerformRespawnTaskObjects(tma, netid)
    if IIsHost() and tma and tma.t and SIMBOARD then
        local task_data = load_var(db.actor, tma.id)
        if type(task_data) ~= "table" then return end
        local target_id = GetExistID(tma.current_target, task_data.squad_id, task_data.target_id, task_data.item_2_id, tma.task_giver_id) or 65535
        local smrt = target_id ~= 65535 and SIMBOARD.smarts[target_id]
        local se = target_id ~= 65535 and alife_object(target_id)
        if not se then return end
        if not simulation_objects.is_on_the_same_level(se, alife():actor()) then
            if IsSquad(se) then
                for k in se:squad_members() do
                    local se_obj = k.object or alife_object(k.id)
                    if se_obj then
                        GameManager:OnEntitySpawned(se_obj, netid or 0)
                    end
                end
            elseif smrt then
                for sq_id, _ in pairs(smrt.squads) do
                    local squad = alife_object(sq_id)
                    if squad then
                        for k in squad:squad_members() do
                            local se_obj = k.object or alife_object(k.id)
                            if se_obj then
                                GameManager:OnEntitySpawned(se_obj, netid or 0)
                            end
                        end
                    end
                end
            else
                GameManager:OnEntitySpawned(se, netid or 0)
            end
            tma.current_target = target_id
            if netid then
                PlayerManager:SyncTaskWith(netid, tma.t, tma.task_giver_id or 65535, tma.stage)
            else
                GameManager:OnIGetTask(tma.t, tma.task_giver_id or 65535, tma.stage or 0)
            end
        end
    end
end

function client_draw_postpone_locally(task_id, SkipSpecial)
    local task_ini = task_manager.task_ini
    if not (task_id and task_ini:section_exist(task_id)) then return nil end

    local OPG = MPMain_GamePatches_ADDONS_STOGETHER
    if OPG and OPG.addoned_draw_postpone_locally and not SkipSpecial then
        return OPG.addoned_draw_postpone_locally(task_id)
    end

    local data    = load_var(db.actor, task_id) or {}
    local title   = game.translate_string(task_ini:r_string_ex(task_id, "title") or "error")
    local icon    = task_ini:r_string_ex(task_id, "icon") or "ui_iconsTotal_mutant"
    local realtbl = type(data) == "table"
    local map     = realtbl and game.translate_string(data.lvl_target or data.target_map or data.map or data.level_name or "")
    local locname = game.translate_string("st_location") .. " " .. game.translate_string(map or level.name())

    -- Fetch task
    local fetch_sec = utils_data.load_var(db.actor, task_id .. "_fetch")
    if fetch_sec then
        local iname = game.translate_string(ini_sys:r_string_ex(fetch_sec, "inv_name") or fetch_sec)
        local fetch_count = fetch_sec and load_var(db.actor, task_id .. "_fetch_count") or 1
        local titlen = game.translate_string("ui_inv_needs") .. ":"
        local extra = ""
        if ini_sys:r_string_ex(fetch_sec, "kind") == "i_arty" then
            extra = " " .. game.translate_string("st_ui_artefact")
        end
        local clr = utils_xml.get_color("pda_white")
        local descr = iname .. extra .. clr .. " (x" .. fetch_count .. ")"
        db.actor:give_talk_message2(titlen, descr, icon, "iconed_answer_item")
        return { titlen, descr, icon, "iconed_answer_item" }
    end

    -- Delivery task
    if realtbl and tasks_delivery.is_delivery_task(task_id) then
        local name = game.translate_string("st_mm_new_game_name") .. " " .. (data.target_name or "")
        local comm = data.target_comm and game.translate_string("st_mm_new_game_faction_2") .. " " .. game.translate_string(data.target_comm) or ""
        local icon = data.target_icon or (data.target_comm and news_manager.tips_icons[data.target_comm]) or icon
        local descr = name .. "\\n " .. comm .. "\\n " .. locname
        db.actor:give_talk_message2(title, descr, icon, "iconed_answer_item")
        return { title, descr, icon, "iconed_answer_item" }
    end

    -- RF Receiver task
    if realtbl and data.freq then
        local titlen = utils_data.parse_string_keys(title, { ["freq"] = data.freq })
        --db.actor:give_talk_message2(titlen, locname, icon, "iconed_answer_item")
        return { titlen, locname, icon, "iconed_answer_item" }
    end

    -- Kill / Rescue
    if realtbl and (data.target_name or data.target_comm or string.find(task_id, "mutant")) then
        local comm = data.target_comm and game.translate_string("st_mm_new_game_faction_2") .. " " .. game.translate_string(data.target_comm) or ""
        local name = data.target_name and game.translate_string("st_mm_new_game_name") .. " " .. game.translate_string(data.target_name) or ""
        local icon = data.target_comm and news_manager.tips_icons[data.target_comm] or icon
        local text = comm .. "\\n " .. name .. "\\n " .. locname
        db.actor:give_talk_message2(title, text, icon, "iconed_answer_item")
        return { title, text, icon, "iconed_answer_item" }
    end

    -- All others
    db.actor:give_talk_message2(title, locname, icon, "iconed_answer_item")
    return { title, locname, icon, "iconed_answer_item" }
end

function Patch()
    log("[GameManager] Patching quests scripts and other shit. For MultiPlayer actions sync")
    mob_trade.GetTalkingNpc = function(netid)
        for k, bstbl in pairs(get_busied_npcs()) do
            if bstbl.busy then
                if k == 65536 then
                    return level.object_by_id(bstbl.id)
                elseif type(netid) == "number" and netid == bstbl.netid then
                    return level.object_by_id(bstbl.id)
                end
            end
        end
        -- Return nil because we have argument - netid.
        -- If this player not using any we can't use current npc if host someone used
        if type(netid) == "number" then return nil end
        return original_talking_npc()
    end
    _G.get_speaker = mob_trade.GetTalkingNpc
    dialogs.request_trade_data = function(netid)
        if not IIsHost() then return end
        local npc = mob_trade.GetTalkingNpc(netid)
        if not npc then return end
        local mdata = alife_storage_manager.get_state()
        if not mdata or not mdata.trade_manager then return end
        log("-[Server] Syncing trade_manager data!")
        local tbl = dup_table(mdata.trade_manager[npc:id()])
        tbl.cfg_ltx = tbl.cfg_ltx:gsub('\\', '/')
        local payload = { npc:id(), tbl }
        GameManager:OnICustomScriptAction("trade_manager", "sync_trade_data", serialize_table_simple(payload), false, netid)
        log("-[Server] Syncing game_difficulties data!")
        local mdata = alife_storage_manager.get_state()
        if not mdata then return end
        local payload = { {}, mdata.diff_eco }
        GameManager:OnICustomScriptAction("game_difficulties", "sync_array_diffs", serialize_table_simple(payload), false, netid)
    end
    trade_manager.sync_trade_data = function(data)
        local mdata = alife_storage_manager.get_state()
        if not mdata then return end
        if not mdata.trade_manager then mdata.trade_manager = {} end
        local loc_id = GameManager:GetLocalIDByServerID(data[1])
        local tbl = data[2]
        local npc = level.object_by_id(loc_id)
        log("-[Client] Syncing trade_manager data!")
        if npc then
            tbl.cfg_ltx = tbl.cfg_ltx:gsub('/', '\\')
            mdata.trade_manager[loc_id] = tbl
            trade_manager.trade_init(npc, tbl.cfg_ltx)
            trade_manager.trade_load(mdata)
        end
    end
    game_difficulties.sync_array_diffs = function(data)
        for k, v in pairs(data[1]) do
            if game_difficulties.get_game_factor(k) ~= v then
                game_difficulties.set_game_factor(k, v)
            end
        end
        for k, v in pairs(data[2]) do
            if game_difficulties.get_eco_factor(k) ~= v then
                game_difficulties.set_eco_factor(k, v)
            end
        end
    end
    dialogs.remote_task_var_sync = function(packet)
        local keyo = packet[1]
        local valo = packet[2]
        local flag = packet[3]
        -- Condition
        if not keyo then
            printf("[TASK-SYNC] Error: remote_task_var_sync received invalid data. Key: %s, Val: %s", tostring(keyo), tostring(valo))
            return
        end
        -- Multivar save table
        if flag then
            printf("[TASK-SYNC] remote_task_var_sync received big data [%s] keys!", #valo)
            for keyB, valB in pairs(valo) do
                dialogs.remote_task_var_sync({ keyB, valB, false })
            end
            return
        end
        -- Awfull converter. Need to rewrite that shit... In engine...
        if type(valo) == "table" and not IIsHost() then
            if valo.target_id then
                valo.target_id = GameManager:GetLocalIDByServerID(tonumber(valo.target_id))
            end
            if valo.item_2_id then
                valo.item_2_id = GameManager:GetLocalIDByServerID(tonumber(valo.item_2_id))
            end
            if valo.squad_id then
                valo.squad_id = GameManager:GetLocalIDByServerID(tonumber(valo.squad_id))
            end
        end
        -- Save vars
        save_var(db.actor, keyo, valo)
    end
    dialogs.remote_sync_available_tasks = function(packet)
        if IIsHost() then return end
        for k, v in pairs(packet) do
            local loc_id = GameManager:GetLocalIDByServerID(k)
            axr_task_manager.available_tasks[loc_id] = v
        end
    end
    dialogs.remote_sync_ongoing_tasks = function(packet)
        if IIsHost() then return end
        for k, v in pairs(packet) do
            local loc_id = GameManager:GetLocalIDByServerID(k)
            axr_task_manager.ongoing_tasks[loc_id] = v
        end
    end
    dialogs.remote_request_generate_tasks = function(netid)
        if not IIsHost() then return end
        local npc = mob_trade.GetTalkingNpc(netid)
        if npc then
            -- Add temp entry for quests generation
            PBusied_NPCS[65536] = { id = npc:id(), busy = true, netid = netid }
            -- Turn off messages to avoid in our npc window
            axr_task_manager.available_tasks[npc:id()] = nil
            axr_task_manager.clear_skipped_tasks()
            local section_npc = npc:section()
            local is_sim = string.find(section_npc, "sim_") or string.find(section_npc, "simulation_")
            axr_task_manager.generate_available_tasks(npc, is_sim)
            axr_task_manager.generate_ongoing_tasks(npc, is_sim)
            -- Preload task variables due we're host. Sync them with client
            for _, tid in ipairs(axr_task_manager.available_tasks[npc:id()] or {}) do
                local on_job_descr = task_manager.task_ini:r_string_ex(tid, "on_job_descr")
                if on_job_descr then
                    local cond = xr_logic.parse_condlist(db.actor, "task_manager", "on_job_descr", on_job_descr)
                    xr_logic.pick_section_from_condlist(db.actor, db.actor, cond)
                end
                local fetch = task_manager.task_ini:r_string_ex(tid, "fetch_descr")
                if fetch then axr_task_manager.trigger_fetch_func(tid) end
                sync_task_variables(tid, netid)
            end
            GameManager:OnICustomScriptAction("dialogs", "remote_sync_available_tasks", serialize_table_simple(axr_task_manager.available_tasks), false, netid)
            -- Clear that temp object for task generator
            PBusied_NPCS[65536] = nil
        end
    end
    axr_task_manager.generate_available_tasks = function(npc, is_sim)
        if IIsHost() then return original_generate(npc, is_sim) end
    end
    function task_manager.CRandomTask:give_task_client(task_id, task_giver_id, client_giver_id)
        local tma = self.task_info[task_id]
        if tma then return end
        OLDGIVETASKSNOW(self, task_id, task_giver_id)
        save_var(db.actor, task_id .. "_owner_net_id", client_giver_id)
    end
    function task_manager.CRandomTask:give_task(task_id, task_giver_id)
        if self.task_info[task_id] then return end
        if IIsHost() then
            self:give_task_client(task_id, task_giver_id)
            sync_task_variables(task_id)
            CreateTimeEvent(task_id, "spawn_entities", 1, function ()
                PerformRespawnTaskObjects(self.task_info[task_id])
                return true
            end)
            return true
        end
        -- Gen data. Not used for sync in realtime. Only when joined on edge of quest to avoid bug!
        -- Host not generate all data due is_talking - false. We forcing sync it! To avoid it...
        sync_task_variables(task_id)
        -- Remote take quest... Without GameManager:OnIGetTask...
        local srv_npc_id = GameManager:GetServerIDByLocalID(task_giver_id or 65535)
        local payload = string.format("%q", task_id)..','..tostring(srv_npc_id)..","..tostring(GameManager:GetMySNETID())
        GameManager:OnICustomScriptAction("task_manager", "get_task_manager():give_task_client", payload, true)
        return true
    end
    -- Used to obtain all tasks again. Because array is clears after skip.
    dialogs.npc_skip_task = function(a, b)
        local npc = dialogs.who_is_npc(a, b)
        local sk = original_npc_skip(a, b)
        if not IIsHost() then
            local tasks = axr_task_manager.available_tasks[npc:id()]
            if not tasks or #tasks == 0 then
                printf("Local task list is empty. Requesting new pool from Host...")
                GameManager:OnICustomScriptAction("dialogs", "remote_request_generate_tasks", tostring(GameManager:GetMySNETID()), true)
            end
        end
        return sk
    end
    -- Generate tasks... Very usefull thing.
    dialogs.text_npc_has_task = function(a, b)
        local npc = dialogs.who_is_npc(a, b)
        local data = original_npc_fetc(a, b)
        if not IIsHost() then
            CreateTimeEvent(npc:id(), "send_message_mp", 0, function()
                local task_tabl = axr_task_manager.available_tasks and axr_task_manager.available_tasks[npc:id()]
                if not task_tabl then return true end
                client_draw_postpone_locally(task_tabl[1])
                return true
            end)
        end
        return data
    end
    function task_manager.CRandomTask:set_task_failed(task_id, force)
        if self.task_info[task_id] and IIsHost() or force then
            self.task_info[task_id].forced_status = "fail"
            GameManager:OnForcedTaskState(task_id, "fail")
        end
    end
    function task_manager.CRandomTask:set_task_completed(task_id)
        if self.task_info[task_id] then
            self.task_info[task_id].forced_status = "complete"
            GameManager:OnForcedTaskState(task_id, "complete")
        end
    end
    function task_objects.CGeneralTask:check_task(tm)
        if not db.actor then return end
        OLDTASKCHECKTSK(self, tm)
        if not IIsHost() then return end
        if MPMain_STOGETHER.GameLoaded then
            local title_changed = self.prev_title ~= self.current_title
            local desc_changed = self.prev_descr ~= self.current_descr
            local stage_changed = self.prev_stage ~= self.stage
            local target_changed = self.prev_stage ~= self.stage
            local is_fetch = self.status_functor == "actor_has_fetch_item"

            if target_changed or title_changed or desc_changed or (stage_changed and not is_fetch) then
                sync_task_variables(self.id)
                GameManager:OnIGetTask(self.t, self.task_giver_id or 65535, self.stage or 0)
                self.prev_title = self.current_title
                self.prev_descr = self.current_descr
                self.prev_stage = self.stage
                self.prev_target = self.current_target
                CreateTimeEvent(self.id, "spawn_entities", 1, function ()
                    PerformRespawnTaskObjects(self)
                    return true
                end)
            end
        end
    end
    dialogs.remote_configure_npc = function (table_data)
        table_data.id = GameManager:GetLocalIDByServerID(table_data.id)
        local npc = level.object_by_id(table_data.id)
        if not npc then return end
        if table_data.busy then
            npc:set_nonscript_usable(false)
            npc:disable_talk()
            -- Prevent player from talk if someone was firstly
            if npc:is_talking() then
                npc:stop_talk()
                db.actor:stop_talk()
            end
        else
            npc:set_nonscript_usable(true)
            npc:enable_talk()
        end
        PBusied_NPCS[table_data.id] = table_data
    end
    dialogs.actor_has_item = function(first_speaker, second_speaker, section)
        return xr_conditions.actor_has_item(first_speaker, second_speaker, { tostring(section) })
    end
    dialogs.drx_sl_give_sl_task = function (a, b)
        local npc = dialogs.who_is_npc(a, b)
        if not npc then return end
        if IIsHost() then return OLDDRXSLGIVE(a, b) end
        local payload = "level.object_by_id(".. tostring(GameManager:GetServerIDByLocalID(npc:id())) ..")"
        GameManager:OnICustomScriptAction("dialogs", "drx_sl_give_sl_task", "db.actor,"..payload, true)
        OLDDRXSLGIVE(a, b)
    end
    dialogs.drx_sl_give_cf_task = function (a, b)
        local npc = dialogs.who_is_npc(a, b)
        if not npc then return end
        if IIsHost() then return OLDDRXCFGIVE(a, b) end
        local payload = "level.object_by_id(".. tostring(GameManager:GetServerIDByLocalID(npc:id())) ..")"
        GameManager:OnICustomScriptAction("dialogs", "drx_sl_give_cf_task", "db.actor,"..payload, true)
        OLDDRXCFGIVE(a, b)
    end
    dialogs.drx_sl_give_mechanic_task = function (a, b)
        local npc = dialogs.who_is_npc(a, b)
        if not npc then return end
        if IIsHost() then return OLDDRXMCGIVE(a, b) end
        local payload = "level.object_by_id(".. tostring(GameManager:GetServerIDByLocalID(npc:id())) ..")"
        GameManager:OnICustomScriptAction("dialogs", "drx_sl_give_cf_task", "db.actor,"..payload, true)
        OLDDRXMCGIVE(a, b)
    end
    xr_conditions.task_giver_alive = function(actor, npc, p)
        if not (p[1]) then
            return false
        end
        local tm = task_manager.get_task_manager()
        local tsk = tm.task_info[p[1]]
        if not tsk then return true end
        local se_obj = tsk.task_giver_id and alife_object(tsk.task_giver_id)
        if not se_obj then return false end
        local cls = se_obj:clsid()
        if IsSquad(nil, cls) then return true end -- if squad exist then atleast 1 npc should be alive
        return (IsMonster(nil, cls) or IsStalker(nil, cls)) and se_obj:alive()
    end
    task_functor.yan_ecolog_semenov_task_target_1 = function(task_id, field, p, tsk)
        if not (db.actor and tsk) then return end
        if not IIsHost() then return tsk.current_target end
        local squad = get_story_squad("yan_ecolog_semenov_squad")
        if squad and (tsk.stage >= 1 or squad.dist_to_actor and squad.dist_to_actor > 50) then
            return squad.id
        end
    end
    dialogs_yantar.give_player_bad_psi_helmet = function(a, b)
        if db.actor:object("bad_psy_helmet") then return end -- MP CAN SHUFFLE HELMET. NEED TO BLOCK THAT DUPE. STUPID!
        if a then dialogs.relocate_money_from_actor(a, b, 10000) end
        alife_create_item("bad_psy_helmet", db.actor)
        news_manager.relocate_item(db.actor, "in", "bad_psy_helmet")
        task_manager.get_task_manager():give_task("turn_off_brain_scorcher")
        if a then
            GameManager:OnICustomScriptAction("dialogs_yantar", "give_player_bad_psi_helmet", "false, db.actor", false)
        end
    end
    dialogs_yantar.give_player_good_psi_helmet = function(a, b)
        if db.actor:object("good_psy_helmet") then return end -- MP CAN SHUFFLE HELMET. NEED TO BLOCK THAT DUPE. STUPID!
        alife_create_item("good_psy_helmet", db.actor)
        news_manager.relocate_item(db.actor, "in", "good_psy_helmet")
        local tm = task_manager.get_task_manager()
        local task_info = tm.task_info
        if task_info and task_info["yan_stalker_sakharov_psi_helmet_upgrade"] then
            tm:set_task_completed("yan_stalker_sakharov_psi_helmet_upgrade")
        end
        tm:give_task("turn_off_brain_machine")
        tm:give_task("turn_off_brain_scorcher")
        if a then
            GameManager:OnICustomScriptAction("dialogs_yantar", "give_player_good_psi_helmet", "false, db.actor", false)
        end
    end
