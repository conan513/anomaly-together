local function generate_ambient_msg(personality, goal, location, enemy_faction)
    local data = ambient_messages[personality] or ambient_messages.Survivor
    local goal_data = data[goal] or data.MutantSlayer
    local p1 = pick_random(goal_data.parts[1])
    local p2 = pick_random(goal_data.parts[2])
    local p3 = pick_random(goal_data.parts[3])
    
    local f1, f2
    if string.find(p1, "%%s") then
        f1 = string.format(p1, location)
        f2 = p2
    else
        f1 = p1
        f2 = string.format(p2, location)
    end
    
    if string.find(f1, "%%s") then f1 = string.format(f1, enemy_faction) end
    if string.find(f2, "%%s") then f2 = string.format(f2, enemy_faction) end
    
    return f1 .. " " .. f2 .. p3
end

-- Centralized Message Queue with De-duplication
local message_queue = {}
local queue_check_cooldown = 20000 -- 20 seconds spacing between messages
local last_queue_delivery_time = 0
local recently_sent = {}
local recently_sent_senders = {}

-- Per-NPC report cooldown: prevents one NPC from generating multiple reports
-- in rapid succession (e.g. killing 5 monsters in a row = 5 reports without this)
-- Keyed by character name to survive A-Life online/offline transition ID changes.
local npc_name_last_report = {}
local NPC_REPORT_COOLDOWN = 90000 -- 90 seconds between reports from the same NPC

-- Per-smart-terrain event cooldown: prevents a single firefight from flooding
-- the queue with one report per casualty (e.g. squad wipe = 8 reports without this)
local smart_last_event = {}
local SMART_EVENT_COOLDOWN = 120000 -- 120 seconds between events from the same location

local function queue_message(message, npc, smart_id)
    local tg = time_global()
    local npc_id = npc and npc:id()
    local npc_name = npc and npc:character_name()
    
    -- Filter out messages from hostile NPCs
    if npc and db.actor and npc:relation(db.actor) == game_object.enemy then
        return
    end
    
    -- HARD LIMIT: one message per NPC per queue cycle.
    -- Also catches same-frame double-kills before the timestamp cooldown can kick in.
    for _, item in ipairs(message_queue) do
        if item.message == message then return end        -- identical text
        if npc_name and item.npc_name == npc_name then return end  -- same sender already waiting
    end
    
    -- Per-NPC cooldown: same NPC can only report once per NPC_REPORT_COOLDOWN ms
    if npc_name then
        local last_t = npc_name_last_report[npc_name]
        if last_t and tg < last_t + NPC_REPORT_COOLDOWN then
            return
        end
        npc_name_last_report[npc_name] = tg
    end
    
    -- Per-smart-terrain cooldown: same location can only produce one event
    -- per SMART_EVENT_COOLDOWN ms regardless of how many NPCs die there
    if smart_id then
        local last_s = smart_last_event[smart_id]
        if last_s and tg < last_s + SMART_EVENT_COOLDOWN then
            return
        end
        smart_last_event[smart_id] = tg
    end
    
    -- Snapshot sender metadata NOW while the NPC object is guaranteed online.
    local sender_meta = nil
    if npc then
        local comm = npc:character_community() or ""
        local comm_name = (comm ~= "") and game.translate_string(comm) or ""
        local npc_name_str = npc_name or "Unknown Stalker"
        local caption = npc_name_str
        if comm_name ~= "" then
            caption = caption .. " (" .. comm_name .. ")"
        end
        sender_meta = {
            caption = caption,
            texture = npc:character_icon() or "ui_iconsTotal_grouping"
        }
    end
    
    table.insert(message_queue, {
        message = message,
        npc_name = npc_name,
        npc_id = npc_id,
        smart_id = smart_id,
        sender = sender_meta
    })
end

-- NPC Response/Reaction logic with Typing Simulator
local function trigger_npc_reaction(smart_id, reporter_id)
    if not smart_id or not reporter_id then return end
    local target_smart = alife_object(smart_id)
    if not target_smart then return end
    
    local candidates = {}
    local tg = time_global()
    for id, st in pairs(db.storage) do
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and id ~= AC_ID and id ~= reporter_id then
            if db.actor and obj:relation(db.actor) ~= game_object.enemy then
                if not alife():has_info(id, "npcx_is_companion") then
                    local npc_name = obj:character_name()
                    local last_t = npc_name and npc_name_last_report[npc_name]
                    if not (last_t and tg < last_t + NPC_REPORT_COOLDOWN) then
                        local comm = obj:character_community()
                        local squad = get_object_squad(obj)
                        
                        -- Exclude traders and unique/quest NPCs
                        local is_safe = (comm ~= "trader") and (get_object_story_id(id) == nil)
                        if is_safe and squad then
                            if get_object_story_id(squad.id) ~= nil then is_safe = false end
                            local sec = squad:section_name()
                            if is_safe and sec and not (string.find(sec, "sim_squad") or string.find(sec, "simulation") or string.find(sec, "_sim_")) then
                                is_safe = false
                            end
                        else
                            is_safe = false
                        end
                        
                        if is_safe and squad then
                            local personality = load_var(obj, "alife_personality")
                            -- Initialize personality if missing
                            if not personality then
                                init_npc(obj)
                                personality = load_var(obj, "alife_personality")
                            end
                            
                            -- Force faction enforcers dynamically for military/duty squads
                            if comm == "dolg" or comm == "army" or comm == "freedom" or comm == "csky" then
                                if math.random(100) < 40 then
                                    personality = "Enforcer"
                                end
                            end
                            
                            local is_busy = false
                            local distress_target = se_load_var(squad.id, nil, "distress_target")
                            if distress_target then
                                local target_smart = SIMBOARD.smarts_by_names[distress_target]
                                if target_smart and target_smart.position then
                                    local dist_to_target = squad.position:distance_to(target_smart.position)
                                    if dist_to_target < 40 then
                                        se_save_var(squad.id, nil, "distress_target", nil)
                                        squad.scripted_target = nil
                                    else
                                        local last_time = se_load_var(squad.id, nil, "distress_time") or 0
                                        local tg_now = time_global()
                                        if tg_now < last_time + 300000 then
                                            is_busy = true
                                        else
                                            se_save_var(squad.id, nil, "distress_target", nil)
                                            squad.scripted_target = nil
                                        end
                                    end
                                else
                                    se_save_var(squad.id, nil, "distress_target", nil)
                                end
                            end
                            
                            if not is_busy then
                                if squad.get_script_target and squad:get_script_target() then
                                    is_busy = true
                                elseif squad.scripted_target and squad.scripted_target ~= "" then
                                    if not distress_target or squad.scripted_target ~= distress_target then
                                        is_busy = true
                                    end
                                end
                            end
                            
                            if not is_busy then
                                table.insert(candidates, {obj = obj, squad = squad, personality = personality, name = npc_name})
                            end
                        end
                    end
                end
            end
        end
    end
    
    if #candidates == 0 then return end
    
    -- 35% chance gate: not every event needs a reaction message.
    -- This prevents the reaction layer from doubling every single combat report.
    if math.random(100) > 35 then return end
    
    -- Pick a random responder candidate
    local responder = candidates[math.random(#candidates)]
    local npc = responder.obj
    local squad = responder.squad
    local personality = responder.personality
    local npc_name = responder.name
    
    local raw_name = target_smart:name()
    local smart_name = game.translate_string(raw_name)
    if not smart_name or smart_name == "" or smart_name == raw_name or string.find(smart_name, "smart_terrain") then
        smart_name = clean_raw_smart_name(raw_name)
    end
    
    -- Procedurally build reaction message
    local msg = generate_reaction_msg(personality, smart_name)
    
    -- Trigger physical pathfinding actions based on profile
    if personality == "Scavenger" or personality == "Aggressor" or personality == "Enforcer" then
        if xsquad and xsquad.acquire_squad then
            pcall(function()
                xsquad.acquire_squad(squad, target_smart, true)
            end)
        else
            squad.scripted_target = target_smart:name()
        end
        se_save_var(squad.id, nil, "distress_target", target_smart:name())
        se_save_var(squad.id, nil, "distress_time", time_global())
    elseif personality == "Coward" then
        local safe_smart = nil
        local min_dist = 999999
        for id, smart in pairs(db.smart_terrain_by_id or {}) do
            if id ~= smart_id and smart.position then
                local dist = npc:position():distance_to(smart.position)
                if dist < min_dist then
                    min_dist = dist
                    safe_smart = smart
                end
            end
        end
        if safe_smart then
            if xsquad and xsquad.acquire_squad then
                pcall(function()
                    xsquad.acquire_squad(squad, safe_smart, true)
                end)
            else
                squad.scripted_target = safe_smart:name()
            end
            se_save_var(squad.id, nil, "distress_target", safe_smart:name())
            se_save_var(squad.id, nil, "distress_time", time_global())
        end
    end
    
    if msg then
        -- Snapshot reactor NPC metadata before the delay fires;
        -- the NPC object pointer may become invalid (offline) by then.
        local comm = npc:character_community() or ""
        local comm_name = (comm ~= "") and game.translate_string(comm) or ""
        local npc_name_str = npc_name or "Unknown Stalker"
        local caption = npc_name_str
        if comm_name ~= "" then
            caption = caption .. " (" .. comm_name .. ")"
        end
        local reactor_sender = {
            caption = caption,
            texture = npc:character_icon() or "ui_iconsTotal_grouping"
        }
        local reactor_id = npc:id()
        
        -- Mark reactor NPC as busy so they cannot appear as a queue reporter
        -- or fire a second reaction within the same cooldown window.
        if npc_name then
            npc_name_last_report[npc_name] = time_global()
        end
        
        -- Calculate typing delay dynamically: 40ms per character + 2-4s thinking delay
        local typing_speed = 0.04
        local base_delay = math.random(2, 4)
        local total_delay = base_delay + (#msg * typing_speed)
        
        CreateTimeEvent(0, "pda_news_reaction_" .. reactor_id, total_delay, function()
            local tg_event = time_global()
            -- Perform queue de-duplication on reaction messages as well
            if not recently_sent[msg] then
                if npc_name and recently_sent_senders[npc_name] and tg_event < recently_sent_senders[npc_name] + queue_check_cooldown then
                    -- Discard reaction because this NPC spoke recently (or simultaneously in queue)
                    return true
                end
                
                recently_sent[msg] = tg_event
                if npc_name then
                    recently_sent_senders[npc_name] = tg_event
                end
                news_manager.send_tip(db.actor, msg, nil, reactor_sender, nil, nil, true)
            end
            return true
        end)
    end
end

local last_ambient_time = 0
local ambient_cooldown = 150000 -- 150 seconds between ambient messages

local function on_actor_update()
    if not IIsHost() then return end
    
    local tg = time_global()
    
    -- Clean up old recently sent messages (older than 300 seconds / 5 minutes)
    for msg, t in pairs(recently_sent) do
        if tg > t + 300000 then
            recently_sent[msg] = nil
        end
    end
    
    -- Clean up old recently sent senders (older than 20 seconds)
    for name, t in pairs(recently_sent_senders) do
        if tg > t + queue_check_cooldown then
            recently_sent_senders[name] = nil
        end
    end
    
    -- Clean up per-NPC and per-smart-terrain cooldown tables
    for name, t in pairs(npc_name_last_report) do
        if tg > t + NPC_REPORT_COOLDOWN then
            npc_name_last_report[name] = nil
        end
    end
    for id, t in pairs(smart_last_event) do
        if tg > t + SMART_EVENT_COOLDOWN then
            smart_last_event[id] = nil
        end
    end
    
    -- Deliver next queued message if cooldown has passed
    if tg > last_queue_delivery_time + queue_check_cooldown then
        if #message_queue > 0 then
            local item = table.remove(message_queue, 1)
            if item then
                -- Final de-duplication check before rendering to screen
                if not recently_sent[item.message] then
                    local sender_name = item.npc_name or (item.sender and item.sender.caption)
                    if sender_name and recently_sent_senders[sender_name] and tg < recently_sent_senders[sender_name] + queue_check_cooldown then
                        -- Skip delivery to avoid spam/duplication from same sender
                    else
                        last_queue_delivery_time = tg
                        recently_sent[item.message] = tg
                        if sender_name then
                            recently_sent_senders[sender_name] = tg
                        end
                        -- Prefer the pre-snapshotted sender metadata (name/icon captured
                        -- at queue time when the NPC was guaranteed online).
                        -- Fall back to a live object lookup only if metadata is missing.
                        local sender = item.sender
                        if not sender then
                            local npc_obj = item.npc_id and level.object_by_id(item.npc_id)
                            sender = (npc_obj and npc_obj:alive()) and npc_obj or nil
                        end
                        news_manager.send_tip(db.actor, item.message, nil, sender, nil, nil, true)
                        
                        -- Trigger reactive NPC actions
                        if item.smart_id and item.npc_id then
                            trigger_npc_reaction(item.smart_id, item.npc_id)
                        end
                    end
                end
            end
        end
    end
    
    -- Queue new ambient message only if the queue is empty and ambient cooldown has passed
    if #message_queue == 0 and tg > last_ambient_time + ambient_cooldown then
        last_ambient_time = tg
        
        local stalkers = {}
        for id, st in pairs(db.storage) do
            local obj = level.object_by_id(id)
            if obj and IsStalker(obj) and obj:alive() and id ~= AC_ID
               and obj:character_community() ~= "trader"
               and get_object_story_id(id) == nil then
                local squad = get_object_squad(obj)
                if squad and get_object_story_id(squad.id) == nil then
                    local sec = squad:section_name()
                    if sec and (string.find(sec, "sim_squad") or string.find(sec, "simulation") or string.find(sec, "_sim_")) then
                        table.insert(stalkers, obj)
                    end
                end
            end
        end
        
        if #stalkers > 0 then
            local npc = stalkers[math.random(#stalkers)]
            
            local enemy_faction = "enemies"
            local my_comm = npc:character_community()
            local hostile_factions = {}
            for faction, _ in pairs({stalker=1, bandit=1, dolg=1, freedom=1, army=1, killer=1, monolith=1}) do
                if game_relations.is_factions_enemies(my_comm, faction) then
                    table.insert(hostile_factions, faction)
                end
            end
            if #hostile_factions > 0 then
                local target_fac = hostile_factions[math.random(#hostile_factions)]
                if target_fac == "stalker" then enemy_faction = "Loners"
                elseif target_fac == "dolg" then enemy_faction = "Duty members"
                elseif target_fac == "freedom" then enemy_faction = "Freedom members"
                elseif target_fac == "csky" then enemy_faction = "Clear Sky members"
                elseif target_fac == "ecolog" then enemy_faction = "Ecologists"
                elseif target_fac == "killer" then enemy_faction = "Mercenaries"
                elseif target_fac == "army" then enemy_faction = "Military patrols"
                elseif target_fac == "bandit" then enemy_faction = "Bandits"
                elseif target_fac == "monolith" then enemy_faction = "Monolith members"
                else enemy_faction = target_fac .. "s"
                end
            end
            
            local location_name = get_nearest_location_name(npc)
            local personality = load_var(npc, "alife_personality")
            local goal = load_var(npc, "alife_goal")
            
            if personality and goal then
                local msg = generate_ambient_msg(personality, goal, location_name, enemy_faction)
                if msg then
                    queue_message(msg, npc, nil)
                end
            end
        end
    end
end

local function npc_on_death_callback(victim, killer)
    if not IIsHost() then return end
    if not victim or not killer then return end
    
    if IsStalker(killer) and killer:alive() and killer:id() ~= AC_ID then
        local personality = load_var(killer, "alife_personality")
        if not personality then
            init_npc(killer)
            personality = load_var(killer, "alife_personality")
        end
        if not personality then return end
        
        local faction = get_community_name(victim)
        local nearest_smart = nil
        local min_dist = 999999
        for id, smart in pairs(db.smart_terrain_by_id or {}) do
            if smart.position then
                local dist = killer:position():distance_to(smart.position)
                if dist < min_dist then
                    min_dist = dist
                    nearest_smart = smart
                end
            end
        end
        
        local location_name = get_nearest_location_name(killer)
        
        -- Procedurally generate death report message
        local message = generate_npc_kill_msg(personality, faction, location_name)
        
        queue_message(message, killer, nearest_smart and nearest_smart.id or nil)
    end
end

local function monster_on_death_callback(victim, killer)
    if not IIsHost() then return end
    if not victim or not killer then return end
    
    if IsStalker(killer) and killer:alive() and killer:id() ~= AC_ID then
        local personality = load_var(killer, "alife_personality")
        if not personality then
            init_npc(killer)
            personality = load_var(killer, "alife_personality")
        end
        if not personality then return end
        
        local nearest_smart = nil
        local min_dist = 999999
        for id, smart in pairs(db.smart_terrain_by_id or {}) do
            if smart.position then
                local dist = killer:position():distance_to(smart.position)
                if dist < min_dist then
                    min_dist = dist
                    nearest_smart = smart
                end
            end
        end
        
        local location_name = get_nearest_location_name(killer)
        
        -- Procedurally generate mutant kill report message
        local message = generate_mutant_kill_msg(personality, location_name)
        
        queue_message(message, killer, nearest_smart and nearest_smart.id or nil)

        -- Trigger physical trophy harvesting
        if M_ALife_Needs_STOGETHER then
            pcall(function()
                M_ALife_Needs_STOGETHER.on_monster_kill(victim, killer)
            end)
        end
    end
end

local function npc_on_net_spawn(npc)
    init_npc(npc)
end

function on_game_start()
    if _G.M_ALIFE_ENHANCEMENTS_REGISTERED then return end
    _G.M_ALIFE_ENHANCEMENTS_REGISTERED = true
    
    -- Global monkey-patch for game.translate_string to clean raw smart terrain names
    if game and game.translate_string then
        local orig_translate_string = game.translate_string
        game.translate_string = function(key)
            if not key then return "" end
            local trans = orig_translate_string(key)
            if trans == key and type(key) == "string" then
                -- Check if it looks like a raw smart terrain key
                if string.find(key, "^[a-z%d]+_smart_terrain_") or string.find(key, "^[a-z%d]+_u_") or string.find(key, "^[a-z%d]+_smart_") then
                    return clean_raw_smart_name(key)
                end
            end
            return trans
        end
    end
    
    RegisterScriptCallback("npc_on_net_spawn", npc_on_net_spawn)
    RegisterScriptCallback("npc_on_death_callback", npc_on_death_callback)
    RegisterScriptCallback("monster_on_death_callback", monster_on_death_callback)
    RegisterScriptCallback("actor_on_update", on_actor_update)
    
    -- Initialize NPC Memory & Reputation module (rescue detection, faction rep, secret stashes)
    M_NPC_Memory_STOGETHER.on_game_start()
    
    -- Initialize Dynamic Economy & Supply Caravans module
    M_Supply_Caravans_STOGETHER.on_game_start()

    -- Initialize Needs & Goals simulation
    if M_ALife_Needs_STOGETHER then
        M_ALife_Needs_STOGETHER.on_game_start()
    end
end
