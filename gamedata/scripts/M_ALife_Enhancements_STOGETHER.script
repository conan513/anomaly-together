    local f2 = string.format(p2, location)
    if string.find(f2, "%%s") then
        f2 = string.format(f2, faction)
    end
    
    return f1 .. " " .. f2 .. p3
end

local function generate_reaction_msg(personality, smart_name)
    local templates = {
        Scavenger = {
            parts = {
                {"Copy that.", "Understood.", "Heard you loud and clear.", "Oh, nice."},
                {"Heading to %s to see if there is any gear or loot left behind.", "Moving to %s to pick the battlefield clean.", "Heading towards %s for salvage.", "On my way to %s to grab some fresh loot."},
                {" Keep the bodies warm.", " Hope they had good stuff.", " Don't loot everything before I arrive."}
            }
        },
        Aggressor = {
            parts = {
                {"Sounds like a firefight near %s!", "Combat reported near %s?", "Gunfire near %s!"},
                {"I'm heading there now to clean up the rest!", "Heading over to join the fun!", "Time to get in on the action!"},
                {" Get ready!", " Leave some targets for me!", " I'm coming hot!"}
            }
        },
        Coward = {
            parts = {
                {"No way, a fight near %s?", "Gunfire near %s?", "Mutants near %s?"},
                {"I'm packing my gear and fleeing!", "Staying inside the safehouse.", "Staying far away from that place."},
                {" Screw this.", " Not paid enough for this.", " I value my skin."}
            }
        },
        Enforcer = {
            parts = {
                {"Understood.", "Tactical report received.", "Dispatching unit."},
                {"Moving squad to %s to secure the sector.", "Patrol unit heading to %s to eliminate hostiles.", "Securing the perimeter of %s."},
                {" Stand down.", " Maintain channel discipline.", " Citizens, stay in cover."}
            }
        },
        Merchant = {
            parts = {
                {"Lots of action near %s.", "A lot of bodies near %s..."},
                {"If anyone survived and needs medical kits or ammo, I've got supplies.", "If you harvested those mutant parts near %s, bring them to me.", "I'm trading near the local hub if you need to restock."},
                {" Rubles ready.", " Fair prices guaranteed.", " Good hunting."}
            }
        },
        Survivor = {
            parts = {
                {"Understood.", "Copy that.", "Roger."},
                {"Glad to hear that threat is dead near %s.", "Another day, another fight near %s.", "Staying alert near %s."},
                {" Safe hunting.", " Keep your heads down.", " Watch your backs."}
            }
        }
    }
    
    local data = templates[personality] or templates.Survivor
    local p1 = pick_random(data.parts[1])
    local p2 = pick_random(data.parts[2])
    local p3 = pick_random(data.parts[3])
    
    local f1, f2
    if string.find(p1, "%%s") then
        f1 = string.format(p1, smart_name)
        f2 = p2
    else
        f1 = p1
        f2 = string.format(p2, smart_name)
    end
    
    return f1 .. " " .. f2 .. p3
end

