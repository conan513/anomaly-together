    trc = "Truck Cemetery"
}

local function get_readable_level_name()
    local name = level.name()
    return level_names[name] or name or "the Zone"
end

local function clean_raw_smart_name(raw_name)
    if not raw_name then return "a sector" end
    
    -- Check prefix (first 3-4 chars before underscore)
    local prefix = string.match(raw_name, "^([%a%d]+)_")
    local rest = string.gsub(raw_name, "^[%a%d]+_", "")
    
    -- Clean up the rest of the raw string
    rest = string.gsub(rest, "smart_terrain_", "")
    rest = string.gsub(rest, "_", " ")
    rest = string.gsub(rest, "%d", "") -- remove numbers
    rest = string.gsub(rest, "%s+", " ") -- collapse multiple spaces
    rest = rest:match("^%s*(.-)%s*$") or rest -- trim
    
    -- Capitalize words
    local words = {}
    for word in string.gmatch(rest, "%S+") do
        local capitalized = word:gsub("^%l", string.upper)
        table.insert(words, capitalized)
    end
    local clean_rest = table.concat(words, " ")
    
    local level_fullname = prefix and smart_prefixes[prefix] or get_readable_level_name()
    if clean_rest == "" or clean_rest == "Smart" or clean_rest == "Terrain" then
        return "somewhere in " .. level_fullname
    end
    return clean_rest .. " in " .. level_fullname
end

local function get_nearest_location_name(npc)
    if not npc then return get_readable_level_name() end
    local pos = npc:position()
    local nearest_name = nil
    local min_dist = 999999
    
    for id, smart in pairs(db.smart_terrain_by_id or {}) do
        if smart.position then
            local dist = pos:distance_to(smart.position)
            if dist < min_dist then
                min_dist = dist
                local raw_name = smart:name()
                if raw_name and raw_name ~= "" then
                    local trans = game.translate_string(raw_name)
                    if trans and trans ~= raw_name and trans ~= "" and not string.find(trans, "smart_terrain") then
                        nearest_name = trans
                    else
                        nearest_name = clean_raw_smart_name(raw_name)
                    end
                end
            end
        end
    end
    
    if nearest_name then
        return nearest_name
    end
    
    return get_readable_level_name()
end

local function get_community_name(npc)
    local comm = npc:character_community()
    if comm == "stalker" then return "Loner"
    elseif comm == "dolg" then return "Duty"
    elseif comm == "freedom" then return "Freedom"
    elseif comm == "csky" then return "Clear Sky"
    elseif comm == "ecolog" then return "Ecologist"
    elseif comm == "killer" then return "Mercenary"
    elseif comm == "army" then return "Military"
    elseif comm == "bandit" then return "Bandit"
    elseif comm == "monolith" then return "Monolith"
    else return comm:gsub("^%l", string.upper)
    end
end

-- NPC initialization for personalities/goals
local function init_npc(npc)
    if not npc or not IsStalker(npc) then return end
    if not npc:alive() then return end
    
    local npc_id = npc:id()
    if npc_id == AC_ID then return end
    
    -- Exclude traders and story/quest NPCs
    if npc:character_community() == "trader" then return end
    if get_object_story_id(npc_id) ~= nil then return end
    
    local squad = get_object_squad(npc)
    if squad then
        if get_object_story_id(squad.id) ~= nil then return end
        local sec = squad:section_name()
        if sec and not (string.find(sec, "sim_squad") or string.find(sec, "simulation") or string.find(sec, "_sim_")) then
            return
        end
    end
    
    local personality = load_var(npc, "alife_personality")
    local goal = load_var(npc, "alife_goal")
    
    if not personality then
        personality = personalities[math.random(#personalities)]
        save_var(npc, "alife_personality", personality)
    end
    if not goal then
        goal = goals[math.random(#goals)]
        save_var(npc, "alife_goal", goal)
    end
end

-- Procedural Sentence Helpers
local function pick_random(tbl)
    return tbl[math.random(#tbl)]
end

local function generate_mutant_kill_msg(personality, location)
    local templates = {
        Scavenger = {
            parts = {
                {"Just harvested a mutant", "Managed to put down a beast", "Got a clean shot on a monster", "Killed a predator"},
                {"near %s", "around the sector of %s", "just outside %s"},
                {". Time to see if the traders will buy these parts.", ". Hopefully the skin is worth some rubles.", ". A bit of quick salvage.", ". Rubles are rubles, right?"}
            }
        },
        Aggressor = {
            parts = {
                {"Hah! Dropped a beast", "That monster didn't stand a chance", "Easy target down", "Blew a mutant to pieces"},
                {"near %s", "right beside %s", "around the ruins of %s", "in the sector of %s"},
                {". My rifle does all the talking!", ". Line up the next one!", ". Who is the apex predator now?", ". Easiest hunt ever."}
            }
        },
        Survivor = {
            parts = {
                {"Barely survived a mutant attack", "That beast almost tore me apart", "Had a very close call with a monster", "Fought off a wild predator"},
                {"near %s", "just outside %s", "around the area of %s"},
                {". Watch out, they are aggressive today.", ". My armor took a beating.", ". I barely got away in one piece.", ". Keep your guns loaded if you walk here."}
            }
        },
        Coward = {
            parts = {
                {"Oh god, a mutant jumped me", "Almost became mutant food", "A beast almost got me", "A monster tried to eat me"},
                {"near %s", "outside %s", "around %s"},
                {". I shot it but my hands are shaking.", ". I'm locking myself in a safe spot.", ". Getting out of here right now."}
            }
        },
        Enforcer = {
            parts = {
                {"Mutant threat neutralized", "Secured the sector from a predator", "Dangerous beast eliminated"},
                {"near %s", "around the perimeter of %s", "in the vicinity of %s"},
                {". Sector is now clear.", ". Area is safe for travelers.", ". Patrol routes are secure."}
            }
        },
        Merchant = {
            parts = {
                {"Secured a mutant kill", "Harvested a high-quality beast", "Got some fresh mutant parts"},
                {"near %s", "around the sector of %s", "close to %s"},
                {". Fresh skins and parts for sale. PM me.", ". Premium trophies ready. Meet me at the local trading hub.", ". Good quality items ready for barter."}
            }
        }
    }
    
    local data = templates[personality] or templates.Survivor
    local p1 = pick_random(data.parts[1])
    local p2 = pick_random(data.parts[2])
    local p3 = pick_random(data.parts[3])
    
    return p1 .. " " .. string.format(p2, location) .. p3
end

