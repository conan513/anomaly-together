    function ui_mutant_loot.UIMutantLoot:SetMutantImage()
        local killed_mutant_tbl = {
            psysucker         = { file = "ui\\ui_actor_monsters_pda_3", x = "393", y = "0", type = "small" },
            lurker            = { file = "ui\\ui_actor_monsters_pda_3", x = "0", y = "0", type = "small" },
            karlik            = { file = "ui\\ui_actor_monsters_pda_3", x = "0", y = "200", type = "small" },
            snork             = { file = "ui\\ui_actor_monsters_pda", x = "393", y = "0", type = "small" },
            dog               = { file = "ui\\ui_actor_monsters_pda", x = "0", y = "800", type = "small" },
            pseudodog         = { file = "ui\\ui_actor_monsters_pda", x = "393", y = "200", type = "small" },
            psy_dog           = { file = "ui\\ui_actor_monsters_pda", x = "393", y = "200", type = "small" },
            poltergeist       = { file = "ui\\ui_actor_monsters_pda", x = "0", y = "400", type = "small" },
            bloodsucker       = { file = "ui\\ui_actor_monsters_pda", x = "393", y = "400", type = "human" },
            controller        = { file = "ui\\ui_actor_monsters_pda", x = "393", y = "800", type = "human" },
            chimera           = { file = "ui\\ui_actor_monsters_pda", x = "0", y = "600", type = "large" },
            tushkano          = { file = "ui\\ui_actor_monsters_pda", x = "0", y = "0", type = "small" },
            rat               = { file = "ui\\ui_actor_monsters_pda", x = "0", y = "0", type = "small" },
            flesh             = { file = "ui\\ui_actor_monsters_pda", x = "393", y = "600", type = "large" },
            tark              = { file = "ui\\ui_actor_monsters_pda_2", x = "0", y = "0", type = "human" },
            rotan             = { file = "ui\\ui_actor_monsters_pda", x = "0", y = "0", type = "human" },
            burer             = { file = "ui\\ui_actor_monsters_pda_1", x = "0", y = "0", type = "large" },
            boar              = { file = "ui\\ui_actor_monsters_pda_1", x = "393", y = "0", type = "large" },
            giant             = { file = "ui\\ui_actor_monsters_pda_1", x = "0", y = "200", type = "large" },
            cat               = { file = "ui\\ui_actor_monsters_pda_2", x = "0", y = "0", type = "small" },
            fracture          = { file = "ui\\ui_actor_monsters_pda_2", x = "393", y = "200", type = "human" },
            bird              = { file = "ui\\ui_actor_monsters_pda_2", x = "393", y = "0", type = "small" },
            zombie            = { file = "ui\\ui_actor_monsters_pda_2", x = "0", y = "200", type = "human" },
            bloodsucker_arena = { file = "ui\\ui_actor_monsters_pda", x = "393", y = "400", type = "human" },
            burer_arena       = { file = "ui\\ui_actor_monsters_pda_1", x = "0", y = "0", type = "large" },
            pseudodog_arena   = { file = "ui\\ui_actor_monsters_pda", x = "393", y = "200", type = "small" },
            snork_arena       = { file = "ui\\ui_actor_monsters_pda", x = "393", y = "0", type = "human" },
        }
        local kind_to_section = {
            ["SM_KARLIK"]    = "karlik",
            ["SM_PSYSUCKER"] = "psysucker",
            ["SM_LURKER"]    = "lurker"
        }
        local mutant_id = game.translate_string(ini_sys:r_string_ex(self.section, "species") or "")
        if not killed_mutant_tbl[mutant_id] then
            return
        end
        local kind = ini_sys:r_string_ex(self.section, "kind") or "unknown"
        mutant_id = kind_to_section[kind] or mutant_id
        local mutant_f = "ui\\ui_actor_monsters_pda_1"
        local mutant_x = ""
        local mutant_y = ""
        mutant_f = tostring(killed_mutant_tbl[mutant_id].file)
        mutant_x = tostring(killed_mutant_tbl[mutant_id].x)
        mutant_y = tostring(killed_mutant_tbl[mutant_id].y)
        local x1 = mutant_x
        local y1 = mutant_y
        local mutant_width = 393
        local mutant_height = 200
        local x2 = x1 + mutant_width
        local y2 = y1 + mutant_height
        self.image:InitTexture(tostring(mutant_f))
        self.image:SetTextureRect(Frect():set(x1, y1, x2, y2))
        self.image:SetStretchTexture(true)
    end
    surge_manager.start_surge = function(pforce)
        local s = surge_manager.get_surge_manager()
        if s then
            s:start(true, pforce)
        end
    end
    surge_manager.stop_surge = function(pforce)
        local s = surge_manager.get_surge_manager()
        if s and s.started then
            s:end_surge(true, pforce)
        end
    end
    function surge_manager.CSurgeManager:start(manual, force)
        if not IIsHost() and not force then return true end
        OLDSURGESTART(self, manual, force)
        GameManager:OnEmissionPsy(false, true)
        return true
    end
    function surge_manager.CSurgeManager:end_surge(manual, force)
        if not IIsHost() and not force then return true end
        OLDSURGESTOP(self, manual, force)
        GameManager:OnEmissionPsy(false, false)
        return true
    end
    if psi_storm_manager then
        psi_storm_manager.start_psi_storm = function(pforce)
            local ps = psi_storm_manager.get_psi_storm_manager()
            if ps then
                ps:start(true, pforce)
            end
        end
        psi_storm_manager.stop_psi_storm = function(pforce)
            local ps = psi_storm_manager.get_psi_storm_manager()
            if ps then
                ps:finish(true, pforce)
            end
        end
        function psi_storm_manager.CPsiStormManager:start(manual, force)
            if not IIsHost() and not force then return true end
            OLDPSISTART(self, manual, force)
            GameManager:OnEmissionPsy(true, true)
            return true
        end
        function psi_storm_manager.CPsiStormManager:finish(manual, force)
            if not IIsHost() and not force then return true end
            OLDPSISTOP(self, manual, force)
            GameManager:OnEmissionPsy(true, false)
            return true
        end
    end
    xr_sound.set_sound_play = function(npc_id, sound, faction, point)
        local data = OLDSETSOUNDPLAY(npc_id, sound, faction, point)
        if IIsHost() then
            local sobj = alife_object(npc_id) or alife():actor()
            GameManager:OnCustomSound(sound, sobj and sobj.position or vector():set(0, 0, 0), sobj)
        end
        return data
    end
    xr_effects.play_sound = function(actor, obj, p)
        OLDSOUNDPLAY(actor, obj, p)
        local sobj = alife_object(obj:id()) or alife():actor()
        if not IIsHost() then
            GameManager:OnCustomSound(p[1], sobj and sobj.position or vector():set(0, 0, 0), sobj)
        end
    end
    xr_sound.set_sound_play_client = function(npc_id, sound, faction, point)
        return OLDSETSOUNDPLAY(npc_id, sound, faction, point)
    end
    xr_conditions.i_has_item = function(actor, npc, p)
        return p[1] and actor and actor:object(p[1])
    end
    xr_conditions.is_enemy_actor = function(enemy, object)
        return enemy and IsActor(enemy)
    end
    xr_conditions.has_actor_enemy = function(actor, npc)
        local best_enemy = npc:best_enemy()
        return best_enemy and IsActor(best_enemy)
    end
    xr_conditions.is_enemy_actor_or_companion = function(enemy, npc)
        if (IsMonster(enemy)) then
            return false
        end
        if not (npc:relation(enemy) >= game_object.enemy) then
            return false
        end
        if xr_conditions.is_enemy_actor(enemy, npc) then
            return true
        end
        if (alife():has_info(enemy:id(), "npcx_is_companion")) then
            return true
        end
        return false
    end
    xr_conditions.fighting_actor = function(actor, npc)
        local enemy_id = db.storage[npc:id()].enemy_id
        local enemy = db.storage[enemy_id] and db.storage[enemy_id].object
        return enemy and IsActor(enemy)
    end
    xr_conditions.killed_by_actor = function(actor, npc)
        local t = db.storage[npc:id()] and db.storage[npc:id()].death
        if t then
            for key, _ in pairs(db.actors) do
                if key == t.killer then
                    return true
                end
            end
        end
        return t and t.killer == actor:id()
    end
    xr_conditions.actor_has_item = function(actor, npc, p)
        if not p[1] then return end
        if IIsHost() then
            if PlayerManager:HasItem(p[1]) then
                return true
            end
        end
        return actor and actor:object(p[1])
    end
    xr_conditions.actor_in_zone = function(actor, npc, p)
        if not (db.actor) then
            return false
        end
        for i = 1, #p do
            local zone = db.zone_by_name[p[i]]
            if zone then
                for _, v in pairs(db.actors) do
                    if v.object and zone and zone:inside(v.object:position()) then
                        return true
                    end
                end
                if zone:inside(db.actor:position()) then
                    return true
                end
            end
        end
        return false
    end
    function ui_sleep_dialog.UISleep:OnButtonSleep()
        for _, p in pairs(db.actors) do
            if p.object then
                if p.object:position():distance_to(db.actor:position()) > 5 then
                    return
                end
            end
        end
        GameManager:OnICustomScriptAction("ui_sleep_dialog", "sleep_test", tostring(self.time_track:GetIValue()), false)
        OLDSLEEPSHIT(self)
    end
    ui_sleep_dialog.dream_callback2 = function()
        OLDSLEEPCAL2()
        GameManager:OnTimeChanged()
        GameManager:OnWeatherChanged(true)
        return true
    end
    ui_sleep_dialog.sleep_test = function(myfuckje)
        disable_info("force_slp2")
        db.actor:give_info_portion("actor_is_sleeping")
        save_var(db.actor, "heli_enemy_flag", nil)
        xr_effects.disable_ui(db.actor, nil)
        level.add_cam_effector("camera_effects\\sleep.anm", 10, false, "ui_sleep_dialog.dream_callback")
        level.add_pp_effector("sleep_fade.ppe", 11, false)
        _G.mus_vol = get_console_cmd(2, "snd_volume_music")
        _G.amb_vol = get_console_cmd(2, "snd_volume_eff")
        exec_console_cmd("snd_volume_music 0")
        exec_console_cmd("snd_volume_eff 0")
        if IIsHost() then
            level.change_game_time(0, myfuckje, 0)
        end
        SendScriptCallback("actor_on_sleep", myfuckje)
    end
    function ph_door.action_door:use_callback(door, actor)
        if not self.object then return end
        if self.st.locked then
            if self.st.snd_open_start then
                xr_sound.set_sound_play(self.object:id(), self.st.snd_open_start)
            end
        end
        self:try_switch()
        GameManager:OnIInteract(self.object:id(), 1, self.st.closed)
    end
    function ui_inventory.UIInventory:Action_Drop(obj, bag)
        obj = self:CheckItem(obj, "Action_Drop")
        db.actor:drop_item(obj)
        self:PlaySND(snd_drop_item)
        GameManager:OnIDrop(obj:id(), 65535)
    end
    function ui_inventory.UIInventory:Action_Drop_All(obj, bag)
        obj = self:CheckItem(obj, "Action_Drop_All")
        local ci = self.CC[bag]:GetCell_ID(obj:id())
        for id, _ in pairs(ci.childs) do
            local obj_c = level.object_by_id(id)
            if obj_c then
                db.actor:drop_item(obj_c)
                GameManager:OnIDrop(obj_c:id(), 65535)
            end
        end
        db.actor:drop_item(obj)
        self:PlaySND(snd_drop_item)
        GameManager:OnIDrop(obj:id(), 65535)
    end
    function axr_radio_in_heli.action_radio_in_heli:execute()
        action_base.execute(self)
        local be = self.object:best_enemy()
        if not be then
            return
        end
    end
    safe_release_manager.release = function(se_obj)
        if type(se_obj) == "number" then
            se_obj = alife_object(se_obj)
        end
        if not se_obj or not se_obj.id then return end      -- no object check
        if se_obj.clsid and IsActor(se_obj) then return end -- Prevent release actor
        OLDSAFEREL(se_obj)
    end
    ranks.get_obj_rank_name = function(obj)
        if not obj then return "" end
        return OLDGRANK(obj)
    end
    ranks.get_se_obj_rank_name = function(obj)
        if not obj then return "" end
        return OLDSRANK(obj)
    end
    ph_door.try_to_open_door = function(npc, opened_doors)
        local npc_position = npc:position()
        for id, position in pairs(db.level_doors) do
            local t = db.storage[id]
            if t and t.ph_door and npc_position:distance_to_sqr(position) <= 3 then
                local action = t.ph_door.door_action
                if action.st.not_for_npc == false and action.st.closed == true then
                    action:use_callback()
                    opened_doors[id] = true
                end
            end
        end
    end
    ph_door.try_to_close_door = function(npc, doors)
        local npc_position = npc:position()
        for id, v in pairs(doors) do
            local t = db.storage[id]
            if t and t.ph_door then
                if npc_position:distance_to_sqr(db.level_doors[id]) > 3 then
                    local action = db.storage[id].ph_door.door_action
                    if not action.st.not_for_npc and not action.st.closed then
                        action:use_callback()
                        doors[id] = nil
                    else
                        doors[id] = nil
                    end
                end
            else
                doors[id] = nil
            end
        end
    end
    ui_pda_npc_tab.generate_date = function(last_msg_date)
        local Y1, M1, D1 = 0, 0, 0
        local Y, M, D, h, m, s, ms = 0, 0, 0, 0, 0, 0, 0
        if last_msg_date then
            Y, M, D = string.match(last_msg_date, "(%d+)/(%d+)/(%d+)")
            Y = tonumber(Y)
            M = tonumber(M)
            D = tonumber(D)
        else
            Y, M, D, h, m, s, ms = game.get_game_time():get(Y, M, D, h, m, s, ms)
        end
        if not Y or not M or not D or not h or not m or not s or not ms then return "ERROR" end
        local diff = D - math.random(1, 30)
        D1 = diff >= 1 and diff or (diff + 29)
        M1 = D1 > D and M - 1 or M
        Y1 = M1 > M and Y - 1 or Y
        return strformat("%s/%s/%s", tostring(Y1), tostring(M1), tostring(D1))
    end
    xr_logic.see_actor = function(npc)
        if not npc or not npc:alive() then return false end
        for _, v in pairs(db.actors) do
            if v.object and npc:see(v.object) then return true end
        end
        return npc:see(db.actor)
    end
    itms_manager.use_place = function (obj)
        local p = obj:parent()
        if not (p and p:id() == AC_ID) then return end
        local section = obj:section()
        alife_release_id(obj:id())    
        local pos = db.actor:position()
        pos:add(device().cam_dir:mul(1.2))
        pos.y = pos.y + 1
        alife_create_special_awaite(function (se_obj)
            printf("Spawned object: %s !", section)
        end, function (se_obj)
            printf("Spawning object: %s !", section)
            local rot = device().cam_dir:getH()
            se_obj.angle = vector():set(0,rot,0)
        end, section, pos, db.actor:level_vertex_id(), db.actor:game_vertex_id())
    end
    treasure_manager.sync_all_stashes = function (PlayerNetID)
        local tbl = {}
        for k, v in pairs(treasure_manager.caches) do
            local se_box = alife_object(k)
            local se_spot = get_stash_spot_type(k)
            tbl[k] = { v, se_box and se_spot and { se_box.id, se_box.position, se_box.m_level_vertex_id, se_box.m_game_vertex_id, se_spot } or nil }
        end
        GameManager:OnICustomScriptAction("treasure_manager", "remote_sync_treasure_caches", serialize_table_simple(tbl), false, PlayerNetID or 0)
    end
    treasure_manager.remote_sync_treasure_caches = function (table)
        for k, v in pairs(table) do
            local mlink = GameManager:GetLocalIDByServerID(k)
            treasure_manager.caches[mlink] = v[1]
            if v[1] and v[2] then
                treasure_manager.remote_add_map_spot(v[2])
            end
        end
    end
    treasure_manager.create_random_stash = function(...)
        if IIsHost() then return OLDTCRRANDOMST(...) end
        GameManager:OnICustomScriptAction("treasure_manager", "remote_create_random_stash", serialize_table_simple({ ... }), true)
    end
    treasure_manager.remote_create_random_stash = function(p)
        treasure_manager.create_random_stash(p[1], p[2], p[3], p[4], p[5])
    end
    treasure_manager.set_random_stash = function(no_spot, hint, bonus_items, id, dbg)
        local result = OLDTSETRNSTASH(no_spot, hint, bonus_items, id, dbg)
        local cachevar = treasure_manager.caches[id]
        local se_box = id and alife_object(id)
        if IIsHost() and se_box and not dbg and type(cachevar) == "string" then
            local payload = { se_box.id, se_box.position, se_box.m_level_vertex_id, se_box.m_game_vertex_id, get_stash_spot_type(se_box.id) }
            GameManager:OnICustomScriptAction("treasure_manager", "remote_add_map_spot", serialize_table_simple(payload), false)
        end
        return result
    end
    treasure_manager.remote_add_map_spot = function(p)
        local real_id = GameManager:GetLocalIDByServerID(p[1])
        local postable = p[2]
        local pos = vector():set(postable[1], postable[2], postable[3])
        pos.y = pos.y - 90
        local lvid = p[3]
        local gvid = p[4]
        local spot_type = p[5]
        local se_exist = alife_object(real_id)
        local target_id = se_exist and se_exist.id

        if not target_id then
            local se_dummy = alife_create_local("inv_backpack", pos, lvid, gvid)
            if se_dummy then target_id = se_dummy.id end
        end

        if target_id and level.map_has_object_spot(target_id, spot_type) == 0 then
            local desc_text = game.translate_string("st_ui_pda_secret")
            level.map_add_object_spot(target_id, spot_type, desc_text)
            treasure_manager.caches[real_id] = true
        end
    end
    treasure_manager.remote_client_clear_treasure = function(srv_id)
        local target_id = GameManager:GetLocalIDByServerID(srv_id)
        if treasure_manager.caches[target_id] then
            level.map_remove_object_spot(target_id, "treasure")
		    level.map_remove_object_spot(target_id, "treasure_searched")
		    level.map_remove_object_spot(target_id, "treasure_unique")
            game_statistics.increment_statistic("stashes_found")
            news_manager.send_treasure(1)
		    local se_stash = alife_object(target_id)
            if not se_stash then return end
		    local lvl = alife():level_name(game_graph():vertex(se_stash.m_game_vertex_id):level_id())
            item_radio.clear_stash(lvl, target_id)
        end
    end
    treasure_manager.try_spawn_treasure = function (box)
        if not box then return end
        if IIsHost() then return OLDTTRYSPAWNIT(box) end
        GameManager:OnICustomScriptAction("treasure_manager", "try_spawn_treasure", "level.object_by_id("..tostring(GameManager:GetServerIDByLocalID(box:id()))..")", true)
    end
    function ui_workshop.UIWorkshopCraft:Craft()
        -- CHECK BEHAVIOUR
        if not self.craft_allow_r then return end
        local payload = {}
        -- ������: �������� ������ � ���������� ������ �����
        local maxcond = 0
        for i = 1, #self.craft_item do
            -- �������� ID ��������� ��� ��������
            if #self.craft_item[i] > 0 then
                for j = 1, #self.craft_item[i] do
                    local item_id = self.craft_item[i][j]
                    local obj = level.object_by_id(item_id)
                    local obj_p = obj and obj:parent()
                    if obj_p then
                        if obj_p:id() == AC_ID or IIsHost() then
                            alife_release(obj)
                        elseif obj_p:id() ~= 0 then
                            table.insert(payload, GameManager:GetServerIDByLocalID(item_id))
                        end
                        local kindergarden = SYS_GetParam(0, obj:section(), "kind")
			            if kindergarden == "i_arty" or kindergarden == "i_arty_cont" and maxcond < obj:condition() then
                            maxcond = obj:condition()
                        end
                    end
                end
            end
            -- �������� ������ �� ��������
            local remain = self.craft_item_remain[i]
            if remain and remain.id and remain.cnt then
                local obj_itm = level.object_by_id(remain.id)
                if obj_itm then
                    if utils_item.discharge(obj_itm, remain.cnt) ~= 0 then
                        engine_perform_special_sync(remain.id)
                    else
                        table.insert(payload, GameManager:GetServerIDByLocalID(remain.id))
                    end
                end
            end
        end
        -- Increase Statistic
        game_statistics.increment_statistic("items_crafted")
        -- Effect
        actor_effects.play_item_fx("craft_dummy")
        -- Craft item that we decide
        if IsItem("ammo", self.craft_item_r[1]) then
            alife_create_item(self.craft_item_r[1], db.actor, { ammo = self.craft_item_r[2] })
        else
            for _ = 1, self.craft_item_r[2] do
                local kind = SYS_GetParam(0, self.craft_item_r[1], "kind")
			    if kind == "i_arty" or kind == "i_arty_cont" then
                    alife_create_item(self.craft_item_r[1], db.actor, { cond = maxcond })
                else
                    alife_create_item(self.craft_item_r[1], db.actor)
                end
            end
        end

        -- Sending to clients request to clear that items in ui or host do releasing
        GameManager:OnICustomScriptAction("ui_workshop", "silent_craft_item", serialize_table_simple(payload), false)

        -- LOST MODDED BEHAVIOUR AND STFU IT
        if self.last_cont and self.last_idx and self.UpdateUi then
            self.btn_craft:Enable(false)
            CreateTimeEvent("totally_not_random_event" .. time_global(), "update_ui_delay" .. time_global(), 0.1, self.UpdateUi, self, self.last_cont, self.last_idx)
        end
    end
    function ui_workshop.UIWorkshopRepair:Repair()
        local obj = self.CC["inventory"]:GetCell_Selected(true)
        if not obj then
            return
        end

        local tot_con = 0
	    local cnt = 0
        local payload = {}
        if is_empty(self.new_con) then
            printf("! UIWorkshopRepair:Repair() | no new parts have been replaced")
            return
        end
        -- Replace parts
        for i = 1, 6 do
            if self.parts[i] and self.parts[i].sec and (self.parts[i].sec ~= "na") then
                if self.new_con[i] and self.new_con[i].id then
                    self.parts[i].con = self.new_con[i].con
                    printf(
                    "- UIWorkshopRepair:Repair() | replaced part spotted | part: %s - condition: %s - order: %s - id: %s",
                        self.parts[i].sec, self.new_con[i].con, i, self.new_con[i].id)

                    -- Release replacement parts
                    local item_id = self.new_con[i].id
                    local se_obj = alife_object(item_id)
                    if se_obj then
                        if se_obj.parent_id == AC_ID or IIsHost() then
                            alife_release(se_obj)
                        else
                            table.insert(payload, GameManager:GetServerIDByLocalID(item_id))
                        end
                    end
                end

                tot_con = tot_con + self.parts[i].con
                cnt = cnt + 1
                printf("/ UIWorkshopRepair:Repair() | total condition calculation | part: %s - condition: %s - order: %s - total sum: %s",
                    self.parts[i].sec, self.parts[i].con, i, tot_con)
            end
        end

        -- Discharge tools
        for i=1,#self.toolkit_pick do
            local toolid = self.toolkit_pick[i]
            local obj_tool = level.object_by_id(toolid)
            if obj_tool then
                if utils_item.discharge(obj_tool) ~= 0 then
                    engine_perform_special_sync(toolid)
                else
                    table.insert(payload, GameManager:GetServerIDByLocalID(toolid))
                end
                printf("/ UIWorkshopRepair:Repair() | discharged toolkit (%s)", self.toolkit_pick[i])
            else
                printe("!ERROR UIWorkshopRepair:Repair() | can't discharge toolkit with id (%s). Object not found!", self.toolkit_pick[i])
            end
        end

        -- Apply condition changes
        local id = obj:id()
        local sec = obj:section()
        sec = ini_sys:r_string_ex(sec,"parent_section") or sec -- for weapons with scopes

        local final_con = cnt > 0 and (clamp(math.ceil(tot_con / cnt), 1, 100) / 100)
        if final_con and final_con >= 0 and final_con <= 1 then
            obj:set_condition(final_con)
            printf("- UIWorkshopRepair:Repair() | object with id (%s) is set to a new condition: %s", id, final_con)
        else
            printe("! UIWorkshopRepair:Repair() | object with id (%s) is either not found. Or didn't register new condition (%s)!", id, final_con)
        end

        local result_part_tbl = {}
        result_part_tbl[sec] = math.ceil(tot_con/cnt)
        for i=1,#self.parts do
            result_part_tbl[self.parts[i].sec] = self.parts[i].con
        end
        item_parts.set_parts_con(id, result_part_tbl)

        for k,v in pairs(result_part_tbl) do
            printf("~ UIWorkshopRepair:Repair() | item's new part table [%s] = %s", k, v)
        end

        -- Effect
        actor_effects.play_item_fx("craft_dummy")

        -- Dirty hack to avoid sync items... Just get to pocket...
        local obj_p = obj:parent()
        if obj_p and obj_p:id() ~= AC_ID then
            obj_p:transfer_item(obj, db.actor)
        end

        -- Sending to clients request to clear that items in ui or host do releasing
        GameManager:OnICustomScriptAction("ui_workshop", "silent_craft_item", serialize_table_simple(payload), false)

        -- Update ui
        if self.last_cont and self.last_idx and self.UpdateUi then
            -- LOST MODDED BEHAVIOUR AND STFU IT
            self.btn_repair:Enable(false)
            CreateTimeEvent("totally_not_random_event" .. time_global(), "update_ui_delay" .. time_global(), 0.1, self.UpdateUi, self, self.last_cont, self.last_idx)
        else
            self:Close()
        end
    end
    ui_workshop.silent_craft_item = function (tbl)
        if IIsHost() then
            for _, id in ipairs(tbl) do
                alife_release_id(id)
            end
        end
        local mui = ui_workshop.GUI and (ui_workshop.GUI.dlg_craft or ui_workshop.GUI.dlg_repair)
        if mui and mui.last_cont and mui.last_idx and mui.UpdateUi then
            mui.btn_craft:Enable(false)
            CreateTimeEvent("totally_not_random_event" .. time_global(), "update_ui_delay" .. time_global(), 0.1, mui.UpdateUi, mui, mui.last_cont, mui.last_idx)
        end
    end
    pda.calculate_rankings = function()
        if IIsHost() then
            orig_calculate_rankings()
        else
            local tg = time_global()
            local coc_ranking_list = pda.get_coc_ranking_list()
            coc_ranking_list[pda.get_rankings_array_size() + 1] = 0
            local my_netid = GameManager:GetMySNETID()
            local my_rank = db.actor:character_rank()
            local payload = { netid = my_netid, rank = my_rank }
            GameManager:OnICustomScriptAction("pda", "host_request_ranking", serialize_table_simple(payload), true)
        end
    end
    pda.host_request_ranking = function(data)
        if not IIsHost() then return end
        local netid = tonumber(data.netid)
        local client_rank = tonumber(data.rank) or 0
        orig_calculate_rankings()
        local list = pda.get_coc_ranking_list()
        local coc_ranking_array_size = pda.get_rankings_array_size()
        local client_place = 1
        local sim = alife()
        if db.actor and db.actor:character_rank() > client_rank then
            client_place = client_place + 1
        end
        if db.actors then
            for n_id, c_data in pairs(db.actors) do
                if n_id ~= netid and c_data.object then
                    if c_data.object:character_rank() > client_rank then
                        client_place = client_place + 1
                    end
                end
            end
        end
        for i = 1, 65534 do
            local se_obj = sim:object(i)
            if se_obj and IsStalker(nil, se_obj:clsid()) and se_obj:alive() then
                local comm = se_obj:community()
                if comm ~= "zombied" and comm ~= "trader" and comm ~= "arena_enemy" then
                    local sid = get_object_story_id(i) 
                    if not sid then
                        if se_obj:rank() > client_rank then
                            client_place = client_place + 1
                        end
                    end
                end
            end
        end
        local network_top = {}
        local MAX_TOP = coc_ranking_array_size or 100
        
        for i = 1, MAX_TOP do
            local id = list[i]
            if not id then break end
            if id == 0 then
                table.insert(network_top, {
                    netid = 0,
                    name = db.actor:character_name(),
                    rank = db.actor:character_rank(),
                    comm = db.actor:character_community(), 
                    rep = db.actor:character_reputation(),
                    icon = db.actor:character_icon() or "ui\\ui_noise",
                    rank_name = ranks.get_obj_rank_name(db.actor),
                    rep_name = string.gsub(utils_obj.get_reputation_name(db.actor:character_reputation()), "st_reputation_", "")
                })
            else
                local c_netid = nil
                local is_requester = false
                if db.actors then
                    for n_id, c_data in pairs(db.actors) do
                        if c_data.object and c_data.object:id() == id then
                            c_netid = n_id
                            if n_id == netid then is_requester = true end
                            break
                        end
                    end
                end
                
                local se_obj = sim:object(id)
                if se_obj then
                    table.insert(network_top, {
                        netid = c_netid,
                        name = se_obj:character_name(),
                        rank = is_requester and client_rank or se_obj:rank(),
                        comm = se_obj:community(),
                        rep = se_obj:reputation(),
                        icon = se_obj:character_icon() or "ui\\ui_noise",
                        rank_name = ranks.get_se_obj_rank_name(se_obj),
                        rep_name = string.gsub(utils_obj.get_reputation_name(se_obj:reputation()), "st_reputation_", "")
                    })
                end
            end
        end
        
        local payload = {
            top = network_top,
            place = client_place
        }
        GameManager:OnICustomScriptAction("pda", "client_receive_ranking", serialize_table_simple(payload), false, netid)
    end
    pda.client_receive_ranking = function(payload)
        if IIsHost() then return end
 
        local network_top = payload.top
        local client_place = tonumber(payload.place) or 9999
        local my_netid = GameManager:GetMySNETID()

        pda.coc_ranking_list = {}
        pda.network_ranking_top = {}
        pda.actor_rank_place = client_place

        local in_top = false
        for i, entry in ipairs(network_top) do
            if entry.netid == my_netid then
                pda.coc_ranking_list[i] = 0
                pda.network_ranking_top[0] = entry
                in_top = true
            else
                local pseudo_id = 65535 + i 
                pda.coc_ranking_list[i] = pseudo_id
                pda.network_ranking_top[pseudo_id] = entry
            end
        end
        if not in_top then
            pda.network_ranking_top[0] = {
                name = db.actor:character_name(),
                rank = db.actor:character_rank(),
                comm = db.actor:character_community(),
                rep = db.actor:character_reputation(),
                icon = db.actor:character_icon() or "ui\\ui_noise",
                rank_name = ranks.get_obj_rank_name(db.actor),
                rep_name = string.gsub(utils_obj.get_reputation_name(db.actor:character_reputation()), "st_reputation_", "")
            }
        end
        pda.coc_ranking_list[pda.get_rankings_array_size() + 1] = 0
    end
    pda.coc_rankings_can_show = function(index)
        if IIsHost() then return orig_coc_rankings_can_show(index) end
        if has_alife_info("ui_pda_hide") then return false end
        if not pda.coc_ranking_list then return false end
        local id = pda.coc_ranking_list[index]
        return id and pda.network_ranking_top and pda.network_ranking_top[id] ~= nil
    end
    pda.coc_rankings_set_name = function(index)
        if IIsHost() then return orig_coc_rankings_set_name(index) end
        if not pda.coc_ranking_list then return "" end
        local id = pda.coc_ranking_list[index]
        local entry = id and pda.network_ranking_top and pda.network_ranking_top[id]
        if entry then
            return strformat("%s. %s", id == 0 and pda.actor_rank_place or index, entry.name)
        end
        return ""
    end
    pda.coc_rankings_set_description = function(index)
        if IIsHost() then return orig_coc_rankings_set_description(index) end
        if not pda.coc_ranking_list then return "" end
        local id = pda.coc_ranking_list[index]
        local entry = id and pda.network_ranking_top and pda.network_ranking_top[id]
        if entry then
            if id == 0 and db.actor then
                entry.rank = db.actor:character_rank()
                entry.rank_name = ranks.get_obj_rank_name(db.actor)
                entry.rep = db.actor:character_reputation()
                entry.rep_name = string.gsub(utils_obj.get_reputation_name(db.actor:character_reputation()), "st_reputation_", "")
                entry.comm = db.actor:character_community()
            end

            local faction_color = "%c[255,255,255,1]"
            if (game_relations.is_factions_enemies(db.actor:character_community(), entry.comm)) then
                faction_color = "%c[255,255,1,1]"
            elseif (game_relations.is_factions_friends(db.actor:character_community(), entry.comm)) then
                faction_color = "%c[255,1,255,1]"
            end

            local repu_color = "%c[255,255,255,1]"
            if (entry.rep <= -500) then repu_color = "%c[255,255,1,1]"
            elseif (entry.rep >= 500) then repu_color = "%c[255,1,255,1]" end

            local faction_str = game.translate_string("ui_st_community") .. ": " .. faction_color .. game.translate_string(entry.comm) .. "%c[default]"
            local rank_str = game.translate_string("ui_st_rank") .. ": " .. "%c[255,215,215,215]" .. game.translate_string("st_rank_" .. entry.rank_name) .. " %c[255,110,110,255]" .. entry.rank .. "%c[default]"
            local repu_str = game.translate_string("ui_st_reputation") .. ": " .. repu_color .. game.translate_string("st_reputation_" .. entry.rep_name) .. "%c[default]"

            return strformat([[ %s \n %s \n %s]], faction_str, rank_str, repu_str)
        end
        return ""
    end
    pda.coc_rankings_set_icon = function(index)
        if IIsHost() then return orig_coc_rankings_set_icon(index) end
        if not pda.coc_ranking_list then return "ui\\ui_noise" end
        local id = pda.coc_ranking_list[index]
        local entry = id and pda.network_ranking_top and pda.network_ranking_top[id]
        if entry then
            if id == 0 then return db.actor:character_icon() end
            return entry.icon or "ui\\ui_noise"
        end
        return "ui\\ui_noise"
    end
    pda.coc_rankings_show_border = function(index)
        if IIsHost() then return orig_coc_rankings_show_border(index) end
        if not pda.coc_ranking_list then return false end
        local id = pda.coc_ranking_list[index]
        return id == 0
    end
    news_manager.send_tip_client = function(data)
        if not db.actor then return end
        if type(data[3]) == "number" then
            local local_id = GameManager:GetLocalIDByServerID(data[3])
            data[3] = level.object_by_id(local_id)
        end
        OLDSENDTIP(db.actor, data[1], data[2], data[3], data[4], data[5])
    end
    news_manager.send_tip_client_new = function(data)
        if not db.actor then return end
        local text = game.translate_string(data.text)
        xr_sound.set_sound_play(AC_ID, "pda_tips")
        db.actor:give_game_news(data.caption, text, data.texture, (data.timeout or 0) * 1000, data.showtime or 5000, 0)
    end
    news_manager.send_tip = function(actor, news_id, timeout, sender, showtime, sender_id, IsGlobal)
        if not actor then return end
        
        local texture = "ui_iconsTotal_grouping"
        local caption = game.translate_string("st_tip")
        
        if sender ~= nil then
            if type(sender) == "string" then
                if news_manager.tips_icons and news_manager.tips_icons[sender] then
                    texture = news_manager.tips_icons[sender]
                end
                caption = game.translate_string(sender)
            elseif type(sender) == "userdata" and sender.clsid then
                texture = sender:character_icon()
                local comm = sender:character_community()
                local comm_name = comm and game.translate_string(comm) or ""
                caption = sender:character_name()
                if comm_name ~= "" then
                    caption = caption .. " (" .. comm_name .. ")"
                end
            elseif type(sender) == "table" then
                texture = sender.texture or texture
                caption = sender.caption or caption
            end
        end
        
        local text = game.translate_string(news_id)
        timeout = timeout or 0
        showtime = showtime or 5000
        
        xr_sound.set_sound_play(AC_ID, "pda_tips")
        actor:give_game_news(caption, text, texture, timeout * 1000, showtime, 0)
        
        if IsGlobal then
            local sync_data = {
                text = news_id,
                timeout = timeout,
                showtime = showtime,
                caption = caption,
                texture = texture
            }
            GameManager:OnICustomScriptAction("news_manager", "send_tip_client_new", serialize_table_simple(sync_data), false)
        end
    end
    dynamic_news_helper.send_tip_client = function(data)
        OLD_DYN_SENDTIP(data[1], data[2], data[3], data[4], data[5], data[6], data[7], true)
    end
    dynamic_news_helper.send_tip = function(...)
        if IIsHost() then
            OLD_DYN_SENDTIP(...)
            GameManager:OnICustomScriptAction("dynamic_news_helper", "send_tip_client", serialize_table_simple({ ... }), false)
        end
    end
    xr_effects.reward_random_money = function(actor, npc, p)
        local multi = game_difficulties.get_eco_factor("rewards") or 1
        local min_val = ( (tonumber(p[1]) or 500) * multi ) / 50
        local max_val = ( (tonumber(p[2]) or (min_val + 1000)) * multi ) / 50
        local money = math.random( math.ceil(min_val), math.ceil(max_val) ) * 50
        db.actor:give_money(money)
	    news_manager.relocate_money(db.actor, "in", money)
        -- Sync random reward_random_money
        local cmd = string.format("db.actor:give_money(%d); news_manager.relocate_money(db.actor, 'in', %d)", money, money)
        GameManager:OnICustomScriptAction(cmd, false)
    end
    xr_effects.reward_random_money_by_dist = function(actor,npc, p)
        local var = load_var(db.actor, p[1])
        local lvl_task = var and var.lvl_task or level.name()
        local lvl_target = var and var.lvl_target
        local n = lvl_task and lvl_target and txr_routes.get_shortest_path_num(lvl_task, lvl_target) or 1
        local multi = game_difficulties.get_eco_factor("rewards") or 1
        local min_val = (tonumber(p[2]) or 500) * multi / 50
        local max_val = (tonumber(p[3]) or (min_val + 1000)) * multi / 50
        local money = math.random( math.ceil(min_val), math.ceil(max_val) ) * 50
        local sweets = math.ceil(n * money * tonumber(p[4] or 0.2))
        local total = money + sweets
        db.actor:give_money(total)
	    news_manager.relocate_money(db.actor, "in", total)
        -- Reward reward_random_money_by_dist
        local cmd = string.format("db.actor:give_money(%d); news_manager.relocate_money(db.actor, 'in', %d)", total, total)
        GameManager:OnICustomScriptAction(cmd, false)
    end
    xr_effects.reward_item = function(actor, npc, p)
        if not (p and p[1]) then return end
        local section_d = p[1]
        local section, uses = utils_item.get_defined_uses(section_d)
        if section == "" or not ini_sys:section_exist(section) then
            printe("!ERROR reward_item | section[%s] doesn't exist", section)
            return
        end
        local cond = nil
        local cls = ini_sys:r_string_ex(section, "class")
        if cls and string.find(cls, "WP_") and cls ~= "WP_KNIFE" then
            cond = math.random(70, 90) / 100
        elseif IsItem("multiuse", section) then
            if not uses then
                local max_uses = ini_sys:r_float_ex(section, "max_uses") or 1
                uses = math.random(1, max_uses)
            end
        end
        local params = { }
        if cond then params.cond = cond end
        if uses then params.uses = uses end
        -- Sync reward item
        alife_create_item(section, db.actor, params)
        news_manager.relocate_item(db.actor, 'in', section, 1)
        local cmd = string.format("alife_create_item(%q, db.actor, %s); news_manager.relocate_item(db.actor, 'in', %q, 1)", section, serialize_table_simple(params), section)
        GameManager:OnICustomScriptAction(cmd, false)
    end
    xr_effects.drx_sl_reward_random_artefact = function(actor, npc, p)
        if not p or not p[1] or not p[2] then return end
        	local reward_items = {
            -- Tier 1
            "af_itcher",
            "af_blood",
            "af_electra_sparkler",
            "af_cristall_flower",
            "af_medusa",
            "af_night_star",
            "af_dummy_glassbeads",
            "af_dummy_battery",
            "af_soul",
            -- Tier 2
            "af_pin",
            "af_mincer_meat",
            "af_sponge",
            "af_lobster_eyes",
            "af_vyvert",
            "af_cristall",
            "af_bracelet",
            "af_ring",
            "af_electra_moonlight",
            "af_empty",
            "af_gravi",
            "af_eye",
            "af_dummy_dummy",
            "af_fuzz_kolobok",
            -- Tier 3
            "af_fireball",
            "af_baloon",
            "af_electra_flash",
            "af_black_spray",
            "af_full_empty",
            "af_gold_fish",
            "af_fire",
            "af_ice",
            "af_glass",
        }

        local reward_tbl = {
            [4000] = 5,
            [5000] = 9,
            [6000] = 14,
            [7000] = 15,
            [9000] = 19,
            [10000] = 20,
            [15000] = 23,
            [20000] = 27,
            [25000] = 32,
        }
        -- Min
        local min_reward_value = tonumber(p[1])
        local min_reward_no = 1
        for val, no in spairs(reward_tbl, function(t,a,b) return a < b end) do
            if min_reward_value >= val then
                min_reward_no = no
            end
        end
        -- Max
        local max_reward_value = tonumber(p[2])
        local max_reward_no = 24
        for val, no in spairs(reward_tbl, function(t,a,b) return a > b end) do
            if max_reward_value < val then
                max_reward_no = no - 1
            end
        end
        -- Syncling things
        local section = reward_items[math.random(min_reward_no, max_reward_no)]
        alife_create_item(section, db.actor)
        news_manager.relocate_item(db.actor, 'in', section, 1)
        local cmd = string.format("alife_create_item(%q, db.actor, %s); news_manager.relocate_item(db.actor, 'in', %q, 1)", section, "{}", section)
        GameManager:OnICustomScriptAction(cmd, false)
    end
    level_input.flags = {}
    level_input.action_quick_save = function(...)
        if not (db.actor:alive() and actor_menu.is_hud_free()) then
            return false
        end
        if level.present() then
            level_input.flags.ret = false
            SendScriptCallback("on_before_save_input", level_input.flags, 2, game.translate_string("st_ui_save"))
            if level_input.flags.ret then
                return true
            end
        end
        if not device():is_paused() then
            device():pause(true)
        end
        local hours = level.get_time_hours()
        local mins = level.get_time_minutes()
        local htag = IIsHost() and "_host" or "_client"
        exec_console_cmd("save " .. tostring(level.name()) .. " " .. tostring(hours) .. "-" .. tostring(mins) .. htag)
        if device():is_paused() then
            device():pause(false)
        end
        return true
    end
    xr_effects.anim_obj_forward = function(actor, npc, p)
        for _, v in pairs(p) do
            local obj = v and db.anim_obj_by_name[v]
            if obj then obj:anim_forward() end
        end
    end
    MPMain_QuestPatches_STOGETHER.Patch()
    -- End of basic game fixes!
    -- Begin of patches for addons and other shit
    if MPMain_GamePatches_ADDONS_STOGETHER then
        MPMain_GamePatches_ADDONS_STOGETHER.Patch()
    end
end

function get_stash_spot_type(id)
    if level.map_has_object_spot(id, "treasure_unique") ~= 0 then
        return "treasure_unique"
    elseif level.map_has_object_spot(id, "treasure_searched") ~= 0 then
        return "treasure_searched"
    elseif level.map_has_object_spot(id, "treasure") ~= 0 then
        return "treasure"
    end
    return nil
end

function receive_special_sync(item_parts_data, usables, conditions)
    local obtained_id_from = (item_parts_data and item_parts_data[1]) or (usables and usables[1]) or (conditions and conditions[1])
    local obtained_var_from = (item_parts_data and item_parts_data[2]) or (usables and usables[2]) or (conditions and conditions[2])
	if not (obtained_id_from and obtained_var_from) then return end
    local id = GameManager:GetLocalIDByServerID(obtained_id_from)
    if item_parts_data then
        log("Overwritting parts data for object ID: " .. tostring(id))
        item_parts.set_parts_con(id, obtained_var_from)
        return true
    end
    CreateTimeEvent(id, "receive_special_sync", 0.1, function ()
        local obj = level.object_by_id(id)
        if not obj then return false end
        local IsUsables = usables and obj:get_remaining_uses() ~= obtained_var_from
        local IsCondata = conditions and obj:condition() ~= obtained_var_from
        log("Overwritting remain uses data for object ID: " .. tostring(id))
        if IsUsables then
            if obj:get_remaining_uses() == 0 then return true end
            log("Overwritting remain uses data for object ID: " .. tostring(id))
            obj:set_remaining_uses(obtained_var_from)
            return true
        elseif IsCondata then
            if obj:condition() == 0 then return true end
            log("Overwritting conditions data for object ID: " .. tostring(id))
            obj:set_condition(obtained_var_from)
            return true
        end
        return true
    end)
end

function engine_perform_special_sync(id, ToPlayerNetID)
    -- Sync Parts
    CreateTimeEvent(id, "receive_special_sync", 0.2, function ()
        local obj = level.object_by_id(id)
        local payload = ""
        local srv_id = GameManager:GetServerIDByLocalID(id)
        if not obj then return false end
        if IsWeapon(obj) or IsOutfit(obj) or IsHeadgear(obj) then
            log("Obtaining weapon/armour parts data! object ID: " .. tostring(id))
            local tbl = item_parts.get_parts_con(obj, id, true)
            payload = serialize_table_simple({ srv_id, tbl }) .. ", nil, nil"
        -- Sync item uses remain
        elseif IsItem("multiuse", obj:section()) then
            log("Obtaining multiuse data! object ID: " .. tostring(id))
            payload = "nil, " .. serialize_table_simple({ srv_id, obj:get_remaining_uses() }) .. ", nil"
        -- Sync item condition %
        elseif utils_item.is_degradable(obj, obj:section()) then
            log("Obtaining degradable data! object ID: " .. tostring(id))
            payload = "nil, nil, " .. serialize_table_simple({ srv_id, obj:condition() })
        end
        -- Just to avoid useless buffer flowing
        if payload == "" then return true end
        -- Send data
        GameManager:OnICustomScriptAction("MPMain_GamePatches_STOGETHER", "receive_special_sync", payload, false, ToPlayerNetID or 0)
        return true
    end)
end

function remote_sync_rank(tbl)
    if not db.actor then return end
    local netid = tbl[3]
    local rank = tbl[2]
    local local_id = GameManager:GetLocalIDByServerID(tbl[1])
    if tbl[3] then
        -- Players
        if netid == GameManager:GetMySNETID() then
            db.actor:set_character_rank(tbl[2])
            game_statistics.increment_statistic(tbl[4] and "killed_monsters" or "killed_stalkers")
        else
            for _, v in pairs(db.actors) do
                if v and v.object and v.snetid == netid then
                    v.object:set_character_rank(rank)
                    break
                end
            end
        end
    else -- Other people and objects...
        local obj = level.object_by_id(local_id)
        if not obj or not IsStalker(obj) then return end
        obj:set_character_rank(rank)
    end
end

function on_entity_death(victim, killer)
    if not (victim and killer) then return end
    local payload = { killer:id(), killer:character_rank(), IsActor(killer) and killer:GetNetID() or false, IsMonster(victim) }
    GameManager:OnICustomScriptAction("MPMain_GamePatches_STOGETHER", "remote_sync_rank", serialize_table_simple(payload), false)
end

function on_game_load()
    if IIsHost() then
        RegisterScriptCallback("npc_on_death_callback", on_entity_death)
        RegisterScriptCallback("monster_on_death_callback", on_entity_death)
    end
end

function on_game_start()
    -- Treasure manager take action sync
    RegisterScriptCallback("actor_on_item_take_from_box", function (box, itm)
        if treasure_manager.caches[box:id()] then
            GameManager:OnICustomScriptAction("treasure_manager", "remote_client_clear_treasure", tostring(GameManager:GetServerIDByLocalID(box:id())), false)
        end
    end)
    -- Another shits register
    RegisterScriptCallback("on_game_load", on_game_load)
    RegisterScriptCallback("save_state", function(m_data)
        if IIsHost() then
            m_data.MP_PDA_CACHE = MP_PDA_CACHE
        end
    end)
    RegisterScriptCallback("load_state", function(m_data)
        if IIsHost() then
            MP_PDA_CACHE = m_data.MP_PDA_CACHE or {}
        end
    end)
end