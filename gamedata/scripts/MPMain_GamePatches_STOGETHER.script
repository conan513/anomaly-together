-- PDA RANKING
local orig_coc_rankings_set_icon = pda.coc_rankings_set_icon
local orig_coc_rankings_show_border = pda.coc_rankings_show_border
local orig_coc_rankings_set_description = pda.coc_rankings_set_description
local orig_coc_rankings_set_name = pda.coc_rankings_set_name
local orig_calculate_rankings = pda.calculate_rankings
local orig_coc_rankings_can_show = pda.coc_rankings_can_show
local orig_register_pda = ui_pda_npc_tab.register_pda
local orig_use_view = ui_pda_npc_tab.use_view
local orig_OnSelectMessage = ui_pda_npc_tab.pda_npc_tab.OnSelectMessage
local orig_unlock_encrypted_pda = ui_pda_npc_tab.unlock_encrypted_pda

function Patch()
    log("[GameManager] Patching game scripts and other shit. For MultiPlayer actions sync")
    ui_pda_npc_tab.register_pda = function(npc, pda_sec, pda_id)
        orig_register_pda(npc, pda_sec, pda_id)
        if IIsHost() then
            local info = se_load_var(pda_id, nil, "info")
            if info then
                local srv_id = GameManager:GetServerIDByLocalID(pda_id)
                if srv_id then
                    MP_PDA_CACHE[srv_id] = info
                end
                CreateTimeEvent(pda_id, "sync_pda", 0.5, function()
                    ui_pda_npc_tab.sync_pda_info(pda_id)
                    return true
                end)
            end
        end
    end
    ui_pda_npc_tab.sync_pda_info = function(pda_id)
        if not pda_id then return end
        local srv_id = GameManager:GetServerIDByLocalID(pda_id)
        local info = srv_id and MP_PDA_CACHE[srv_id] or se_load_var(pda_id, nil, "info")
        if srv_id and info then
            local payload = { srv_id, info }
            GameManager:OnICustomScriptAction("ui_pda_npc_tab", "remote_receive_pda_info", serialize_table_simple(payload), false)
        end
    end
    ui_pda_npc_tab.remote_receive_pda_info = function(data)
        if IIsHost() then return end
        local srv_id = data[1]
        local info = data[2]
        if srv_id and info then
            MP_PDA_CACHE[srv_id] = info
            local pda_id = GameManager:GetLocalIDByServerID(srv_id)
            if pda_id then
                se_save_var(pda_id, nil, "info", info)
            end
        end
    end
    ui_pda_npc_tab.use_view = function(obj)
        if obj then
            local id = obj:id()
            local info = se_load_var(id, nil, "info")
            if not info then
                local srv_id = GameManager:GetServerIDByLocalID(id)
                if srv_id and MP_PDA_CACHE[srv_id] then
                    se_save_var(id, nil, "info", MP_PDA_CACHE[srv_id])
                else
                    local contact = {
                        name = game.translate_string("st_dyn_news_unknown_contact"),
                        comm = "stalker",
                        icon = "ui_inGame2_neutral_1",
                        rank = "novice",
                        repu = 0
                    }
                    local new_info = { state = "default", contact = contact, msg = {} }
                    se_save_var(id, nil, "info", new_info)
                end
            end
        end
        orig_use_view(obj)
    end
    ui_pda_npc_tab.pda_npc_tab.OnSelectMessage = function(self)
        local item = self.message_list:GetSelectedItem()
        if not item then return end
        local indx = item.indx
        local msg = self.msg[indx]
        local needs_host = false
        if msg.stash and not msg.stash_read then needs_host = true end
        if msg.route and not msg.route_read then needs_host = true end 
        if not IIsHost() and needs_host then
            local pda_id = nil
            db.actor:iterate_inventory(function(_, obj)
                if item_device.device_npc_pda[obj:section()] then
                    local info = se_load_var(obj:id(), obj:name(), "info")
                    if info and info.contact and info.contact.name == self.contact.name then
                        pda_id = obj:id()
                    end
                end
            end, db.actor)
            if pda_id then
                local srv_id = GameManager:GetServerIDByLocalID(pda_id)
                GameManager:OnICustomScriptAction("ui_pda_npc_tab", "remote_process_pda_message", serialize_table_simple({srv_id, indx}), true)
            end
            local temp_stash = msg.stash
            local temp_route = msg.route
            msg.stash = nil
            msg.route = nil
            orig_OnSelectMessage(self)
            msg.stash = temp_stash
            msg.route = temp_route
            if temp_stash then msg.stash_read = true end
            if temp_route then msg.route_read = true end
            return
        end
        orig_OnSelectMessage(self)
        if IIsHost() and needs_host then
            local pda_id = nil
            db.actor:iterate_inventory(function(_, obj)
                if item_device.device_npc_pda[obj:section()] then
                    local info = se_load_var(obj:id(), obj:name(), "info")
                    if info and info.contact and info.contact.name == self.contact.name then
                        pda_id = obj:id()
                    end
                end
            end, db.actor)
            ui_pda_npc_tab.sync_pda_info(pda_id)
        end
    end
    ui_pda_npc_tab.remote_process_pda_message = function(data)
        if not IIsHost() then return end
        local srv_id = data[1]
        local indx = data[2]
        local info = MP_PDA_CACHE[srv_id]
        local loc_id = GameManager:GetLocalIDByServerID(srv_id)
        if not info and loc_id then
            info = se_load_var(loc_id, nil, "info")
        end
        if info and info.msg and info.msg[indx] then
            local msg = info.msg[indx]
            if msg.stash and not msg.stash_read then
                local hint = "%c[255,255,160,0]" .. game.translate_string(msg.topic_title) .. "\\n%c[default]" .. "\\n%c[160,100,100,200]" .. game.translate_string("st_stash_of") .. " " .. info.contact.name
                treasure_manager.set_random_stash( nil , hint , nil , msg.stash)
                msg.stash_read = true
                msg.topic[1] = msg.topic[1] or (game.translate_string("st_stash_of") .. " " .. info.contact.name)
            end
            if msg.route and not msg.route_read then
                txr_routes.open_route(msg.route[1], msg.route[2])
                msg.route_read = true
                local route_payload = { msg.route[1], msg.route[2] }
                GameManager:OnICustomScriptAction("ui_pda_npc_tab", "remote_sync_route", serialize_table_simple(route_payload), true)
            end
            MP_PDA_CACHE[srv_id] = info
            if loc_id then
                se_save_var(loc_id, nil, "info", info)
            end
            local payload = { srv_id, info }
            GameManager:OnICustomScriptAction("ui_pda_npc_tab", "remote_receive_pda_info", serialize_table_simple(payload), false)
        end
    end
    ui_pda_npc_tab.remote_sync_route = function(data)
        if not alife_storage_manager.get_state().discovered_routes then
            alife_storage_manager.get_state().discovered_routes = {}
        end
        local str1 = data[1] .. "_" .. data[2]
        local str2 = data[2] .. "_" .. data[1]
        alife_storage_manager.get_state().discovered_routes[str1] = true
        alife_storage_manager.get_state().discovered_routes[str2] = true
    end
    ui_pda_npc_tab.unlock_encrypted_pda = function(first_speaker, second_speaker)
        local encrypted_pdas = ui_pda_npc_tab.get_encrypted_pdas()
        local payload_ids = {}
        for i=1, #encrypted_pdas do
            table.insert(payload_ids, GameManager:GetServerIDByLocalID(encrypted_pdas[i]))
        end
        orig_unlock_encrypted_pda(first_speaker, second_speaker)
        for i=1, #payload_ids do
            local srv_id = payload_ids[i]
            if srv_id and MP_PDA_CACHE[srv_id] then
                MP_PDA_CACHE[srv_id].state = "default"
            end
        end
        if #payload_ids > 0 then
            local payload_str = serialize_table_simple(payload_ids)
            if not IIsHost() then
                GameManager:OnICustomScriptAction("ui_pda_npc_tab", "remote_unlock_pdas", payload_str, true)
            end
        end
    end
    ui_pda_npc_tab.remote_unlock_pdas = function(data)
        for i=1, #data do
            local srv_id = data[i]
            if srv_id then
                if MP_PDA_CACHE[srv_id] then
                    MP_PDA_CACHE[srv_id].state = "default"
                end
                local loc_id = GameManager:GetLocalIDByServerID(srv_id)
                if loc_id then
                    local info = se_load_var(loc_id, nil, "info")
                    if info then
                        info.state = "default"
                        se_save_var(loc_id, nil, "info", info)
                    end
                end
            end
        end
        if IIsHost() then
            GameManager:OnICustomScriptAction("ui_pda_npc_tab", "remote_unlock_pdas", serialize_table_simple(data), false)
        end
    end
    bind_stalker_ext.clear_death_logo = function ()
        local hud = get_hud()
        if hud then hud:RemoveCustomStatic("text_on_screen_center") end
        level.remove_pp_effector(2001)
        level.enable_input()
    end
    bind_stalker_ext.death_manager_mp = function (reload, show_message)
        level.disable_input()
        local hud = get_hud()
        if hud then hud:HidePdaMenu() end
        -- Draw death message
        if show_message then
            level.add_pp_effector("deimos1.ppe", 2001, true)
            local msg = game.translate_string("DR_DeathMSG")
            if msg == "DR_DeathMSG" then msg = "CRITICAL MISSION FAILURE" end
            if hud then
                hud:AddCustomStatic("text_on_screen_center", true)
                local static = hud:GetCustomStatic("text_on_screen_center")
                if static then
                    static:wnd():TextControl():SetText(msg)
                    static:wnd():TextControl():SetTextColor(GetARGB(255, 255, 50, 50))
                end
            end
        end
        if not reload then
            -- If show message it's mean wait for resurrecting
            if show_message then return end
            -- Resur
            db.actor:set_health_ex(1)
            db.actor.power = 1
            db.actor.radiation = 0
            db.actor.bleeding = 1
            db.actor.satiety = 1
            db.actor.psy_health = 1
            if arszi_psy then arszi_psy.set_psy_health(1.0) end
            if bind_stalker_ext then bind_stalker_ext.invulnerable_time = time_global() + 10000 end
            -- Respawn on bases or turned on campfires...
            -- Search smart for resurrection and ressurecting!
            local acpos = db.actor:position()
            local ndist = 9999
            local ncpos = nil
            local community = gameplay_disguise.get_default_comm()
            for _, smart in pairs(SIMBOARD.smarts_by_names) do
                if smart.is_on_actor_level and smart.props.base > 0 then
                    local smart_coma = smart.props[community] or 0
                    if smart_coma > 0 or smart.props.all > 0 then
                        for _, faction in pairs(game_relations.factions_table) do
                            local relation = relation_registry.community_relation(faction, community)
                            local goodwill = relation_registry.community_goodwill(faction, db.actor:id())
                            if relation + goodwill >= 0 then
                                local mdist = smart.position:distance_to(acpos)
                                if mdist < ndist then
                                    ndist = mdist
                                    ncpos = smart.position
                                end
                            end
                        end
                    end
                end
            end
            -- Search campfire for resurrection!
            for _, binder in pairs(bind_campfire.campfires_all) do
                if binder and binder.object and binder.campfire and binder.campfire:is_on() then
                    local mdist = binder.object:position():distance_to(acpos)
                    if mdist < ndist then
                        ndist = mdist
                        ncpos = binder.object:position()
                    end
                end
            end
            -- Ressurect on nearest position campfires or smart zone
            if ncpos then
                printf("-[Client] Found safe campfire. ressurecting near it!")
                bind_stalker_ext.clear_death_logo()
                local cdir = device().cam_dir
                local spos = ncpos:add(cdir)
                db.actor:set_actor_position(spos)
                return
            end
            -- Resurrect failed, no free bases. Kill our self
            printf("-[Client] Can't find bases and campfires for resurrect place... Reloading save.")
            bind_stalker_ext.clear_death_logo()
            bind_stalker_ext.death_manager_mp(true, true)
            GameManager:OnICustomScriptAction("bind_stalker_ext", "death_manager_mp", "true, true", false)
            db.actor:kill(db.actor, true)
            return
        end
        -- Restart server. Delay of reload before
        if IIsHost() then
            CreateTimeEvent(0, "hc_reload_timer", MPMain_STOGETHER.TimeEResurrect, function()
                level.remove_pp_effector(PPE_ID)
                level.enable_input()
                get_console():execute("reconnect")
                return true
            end)
        end
    end
    bind_stalker_ext.actor_on_before_death = function(binder, whoID)
        if MPMain_STOGETHER.IDead then return end
        MPMain_STOGETHER.IDead = true
        -- Why not...
        local flags = { ret_value = false }
        if not MPMain_STOGETHER.AllowResurrect then
            SendScriptCallback("actor_on_before_death", whoID, flags)
            -- Kill us if allowed
            if not flags.ret_value then
                bind_stalker_ext.death_manager_mp(true, true)
                GameManager:OnICustomScriptAction("bind_stalker_ext", "death_manager_mp", "true, true", false)
                db.actor:kill(db.actor, true)
            end
            -- IDK WHY... BUT HERE MUST BE ANOTHER ADDON CALL THAT flags.
            -- We cant go here because resurrect allow flag flase!
            return
        end
        if MPMain_STOGETHER.DropInvOnDeath then
            log("[MLEVELM] Dropping actor inventory. We dead")
            alife_create_awaite(function(se_obj)
                if se_obj then
                    local m_data = alife_storage_manager.get_state()
                    if not m_data.player_created_stashes then m_data.player_created_stashes = {} end
                    m_data.player_created_stashes[se_obj.id] = "itm_backpack"
                    level.map_add_object_spot_ser(se_obj.id, "treasure", "MYLOOT")
                    local function drop_items(boxid)
                        local obj = level.object_by_id(boxid)
                        if obj then
                            local function itr_inv(_, item)
                                db.actor:transfer_item(item, obj)
                                SendScriptCallback("actor_on_item_put_in_box", obj, item)
                            end
                            db.actor:iterate_ruck(itr_inv, nil)
                            return true
                        end
                        return false
                    end
                    CreateTimeEvent(0, "actor_backpack", 0, drop_items, se_obj.id)
                end
            end, "inv_backpack", db.actor:position(), db.actor:level_vertex_id(), db.actor:game_vertex_id())
        elseif MPMain_STOGETHER.ClearInvOnDeath then
            log("[MLEVELM] Clearing actor inventory. We dead")
            local function itr_inv(_, item)
                alife_release_full(item)
            end
            db.actor:iterate_ruck(itr_inv, nil)
        end
        -- RESURRECT AFTER DELAY
        CreateTimeEvent(0, "resurrect_action", MPMain_STOGETHER.TimeEResurrect, function()
            bind_stalker_ext.death_manager_mp(false, false)
            MPMain_STOGETHER.IDead = false
            -- reset animation...
            GameManager:OnICustomAnimation("waunded_1_idle_0", "", true, 1)
            return db.actor.health > 0.2
        end)
        -- Dead animation until we ressurecting...
        GameManager:OnICustomAnimation("waunded_1_idle_0", "", true, 340000)
        -- Show local picture and text
        bind_stalker_ext.death_manager_mp(false, true)
    end
    bind_campfire.campfire_go_off = function(cf, obj)
        local cf = cf or get_nearby_campfire(dist_cf, true)
        if cf and (cf:is_on()) then
            actor_effects.play_item_fx("matches_script")
            cf:turn_off()
            GameManager:OnIInteract(obj:id(), 0, false)
        end
    end
    bind_campfire.campfire_go_on = function(obj, cf)
        local dist_cf = 2
        local cf = cf or bind_campfire.get_nearby_campfire(dist_cf, true)
        if not cf then
            return
        end
        if cf:is_on() then
            return
        end
        if bind_campfire.rain_pass() then
            actor_effects.play_item_fx("matches_script")
            xr_sound.set_sound_play(AC_ID, "inv_matches")
            cf:turn_on()
            GameManager:OnIInteract(obj:id(), 0, true)
        else
            actor_effects.play_item_fx("matches_script")
            actor_menu.set_msg(1, game.translate_string("st_fail"), 3)
        end
    end
    bind_campfire.actor_on_item_use = function(obj, cfo, cf)
        local sec = obj:section()
        if (sec == "matches") or (sec == "box_matches") then
            bind_campfire.campfire_go_on(cfo, cf)
            utils_item.discharge(obj)
        end
    end
    bind_campfire.use_campfire = function(actor, zone, p) -- called from game_tutorials.xml
        local pos = db.actor:position()
        for id, binder in pairs(bind_campfire.campfires_all) do
            if (binder and binder.campfire) then
                if (pos:distance_to_sqr(binder.object:position()) <= 2) then
                    if (binder.campfire:is_on()) then
                        bind_campfire.campfire_go_off(binder.campfire, binder.object)
                    else
                        local obj_item = db.actor:object("matches") or db.actor:object("box_matches")
                        if obj_item then
                            bind_campfire.actor_on_item_use(obj_item, binder.object, binder.campfire)
                        else
                            actor_menu.set_msg(1, game.translate_string("st_ui_campfire_prereq"), 3)
                        end
                    end
                end
            end
        end
    end
    itms_manager.use_guitar = function(obj)
        local n = math.random(28)
        local snd = sound_object("music\\guitar_" .. tostring(n))
        if (not snd) then return end
        local period = snd:length()
        snd:play_no_feedback(db.actor, 0, 0, db.actor:position(), 1.0, 1.0)
        actor_effects.play_continuous_effect(period)
        GameManager:OnICustomAnimation("guitar_0", obj:section(), true, period / 1000, "music\\guitar_" .. tostring(n))
    end
    itms_manager.use_harmonica = function(obj)
        local n = math.random(5)
        local snd = sound_object("music\\harmonica_" .. tostring(n))
        if (not snd) then return end
        local period = snd:length()
        snd:play_no_feedback(db.actor, 0, 0, db.actor:position(), 1.0, 1.0)
        actor_effects.play_continuous_effect(period)
        GameManager:OnICustomAnimation("harmonica_0", obj:section(), true, period / 1000,
            "music\\harmonica_" .. tostring(n))
    end
    function ph_button.ph_button:__init(obj, storage)
        self.object = obj
        self.st = storage
        storage.button_action = self
    end
    function ph_button.ph_button:use_callback(victim, who)
        if not self.object then return end
        GameManager:OnICustomAnimation("knopka_0", "", true, 1.7)
        GameManager:OnIInteract(self.object:id(), 2, true)
        self:try_switch()
    end
    function ui_debug_launcher.UIDebug_ObjSpawn:Spawn(section)
        -- Get group name
        local obj_to_spawn_classes = {
            -- kind
            ["AI_STL_S"]     = "NPC (Stalker)",
            ["AI_TRD_S"]     = "NPC (Stalker)",

            ["SM_KAR"]       = "NPC (Mutant)",
            ["SM_BLOOD"]     = "NPC (Mutant)",
            ["SM_BOARW"]     = "NPC (Mutant)",
            ["SM_BURER"]     = "NPC (Mutant)",
            ["SM_CAT_S"]     = "NPC (Mutant)",
            ["SM_CHIMS"]     = "NPC (Mutant)",
            ["SM_CONTR"]     = "NPC (Mutant)",
            ["SM_DOG_S"]     = "NPC (Mutant)",
            ["SM_FLESH"]     = "NPC (Mutant)",
            ["SM_IZLOM"]     = "NPC (Mutant)",
            ["SM_GIANT"]     = "NPC (Mutant)",
            ["SM_POLTR"]     = "NPC (Mutant)",
            ["SM_P_DOG"]     = "NPC (Mutant)",
            ["SM_DOG_P"]     = "NPC (Mutant)",
            ["SM_DOG_F"]     = "NPC (Mutant)",
            ["SM_SNORK"]     = "NPC (Mutant)",
            ["SM_TUSHK"]     = "NPC (Mutant)",
            ["SM_ZOMBI"]     = "NPC (Mutant)",
            ["SM_RAT"]       = "NPC (Mutant)",
            ["SM_KARLIK"]    = "NPC (Mutant)",
            ["SM_LURKER"]    = "NPC (Mutant)",
            ["SM_PSYSUCKER"] = "NPC (Mutant)",

            ["C_HLCP_S"]     = "Vehicles",
            ["C_NIVA"]       = "Vehicles",
            ["SCRPTCAR"]     = "Vehicles",

            ["ON_OFF_S"]     = "Squads",

            ["O_PHYSIC"]     = "Physic (Misc.)",
            ["O_DSTRBL"]     = "Physic (Misc.)",
            ["P_DSTRBL"]     = "Physic (Misc.)",
            ["O_PHYS_S"]     = "Physic (Misc.)",
            ["O_DSTR_S"]     = "Physic (Misc.)",
            ["S_INVBOX"]     = "Physic (Misc.)",
            ["O_INVBOX"]     = "Physic (Misc.)",
            ["S_EXPLO"]      = "Physic (Misc.)",
            ["II_EXPLO"]     = "Physic (Misc.)",

            ["ZS_MBALD"]     = "Anomaly",
            ["ZS_GALAN"]     = "Anomaly",
            ["ZS_MINCE"]     = "Anomaly",
            ["ZS_RADIO"]     = "Anomaly",
            ["ZS_TORRD"]     = "Anomaly",
            ["ZS_NGRAV"]     = "Anomaly",
            ["Z_MBALD"]      = "Anomaly",
            ["Z_RADIO"]      = "Anomaly",
            ["Z_CFIRE"]      = "Anomaly",
            ["Z_NOGRAV"]     = "Anomaly",
            ["Z_TORRID"]     = "Anomaly",
            ["Z_RUSTYH"]     = "Anomaly",
            ["ZS_BFUZZ"]     = "Anomaly",
            ["ZS_AMEBA"]     = "Anomaly",

            ["AI_PHANT"]     = "Phantom",
        }
        local class = ini_sys:r_string_ex(section, "class")
        local kind = ini_sys:r_string_ex(section, "kind") -- special class name for the sake of correct listing
        if kind then class = kind end
        local group = obj_to_spawn_classes[class]
        local ext = ""

        -- Properties
        local prop = {}
        local is_squad = string.find(group, "Squad")
        local cant_spawn_actor = string.find(group, "NPC") or string.find(group, "Physic")
        local is_veh = string.find(group, "Vehicles")
        local is_anom = string.find(group, "Anomaly")
        local is_phantom = string.find(group, "Phantom")
        if (is_squad) then
            prop.no_id         = true
            prop.squad         = true
            prop.spawn_at_look = true
        elseif (cant_spawn_actor) then
            prop.no_id         = true
            prop.spawn_at_look = true
        elseif (is_veh) then
            prop.no_id         = true
            prop.spawn_at_look = true
        elseif (is_anom) then
            prop.no_id         = true
            prop.spawn_at_look = true
            prop.is_anom       = true
        elseif (is_phantom) then
            prop.no_id           = true
            prop.spawn_at_look   = true
            prop.use_level_spawn = true
        end

        -- checks
        local chk_smart  = self.d14_chk_s:GetCheck()
        local chk_point  = self.d15_chk_p:GetCheck()
        local smart_name = string.sub(self.d14_list_smrt:GetText(), 1, -2)

        if smart_name and (smart_name ~= "") and SIMBOARD.smarts_by_names[smart_name] then
            chk_smart = chk_smart and true or false
        else
            chk_smart = false
        end

        -- Spawn
        local pos, lvid, gvid
        if chk_smart then
            local smrt = SIMBOARD.smarts_by_names[smart_name]
            local se_smart = alife_object(smrt.id)
            if se_smart then
                pos = se_smart.position
                lvid = se_smart.m_level_vertex_id
                gvid = se_smart.m_game_vertex_id
                ext = strformat("at smart [%s]", smart_name)
            end
        elseif (prop.spawn_at_look) and chk_point then
            gvid = db.actor:game_vertex_id()
            local r = level.get_target_dist and level.get_target_dist() or 3
            pos = vector():set(db.actor:position())
            pos:add(device().cam_dir:mul(r))
            pos = vector():set(pos.x, db.actor:position().y, pos.z)
            lvid = level.vertex_id(pos)
            ext = "at cursor"
        else
            pos = db.actor:position()
            lvid = db.actor:level_vertex_id()
            gvid = db.actor:game_vertex_id()
            ext = "near actor"
        end

        if (prop.use_level_spawn) then
            if (level.spawn_item) then
                level.spawn_item(section, pos, lvid, 65535, false)
                self:SetMsg(strformat("Spawned object [%s] using level spawn", section), "-")
            end
            return
        end
        local se_obj = section and alife_create_client(section, pos, lvid, gvid)
        if se_obj then
            if (prop.squad) then
                local smrt
                if (chk_smart) then
                    smrt = SIMBOARD.smarts_by_names[smart_name]
                    if smrt then
                        se_obj:create_npc(smrt)
                    end
                else
                    se_obj:create_npc(nil, pos, lvid, gvid)
                end
                local sim = alife()
                for k in se_obj:squad_members() do
                    local se_npc = k.object or k.id and sim:object(k.id)
                    if (se_npc) then
                        SIMBOARD:setup_squad_and_group(se_npc)
                        SendScriptCallback("squad_on_npc_creation", se_obj, se_npc, smrt)
                    end
                end
                self:SetMsg(strformat("Spawned squad [%s] (%s) %s", section, se_obj.id, ext), "-")
            elseif (prop.is_anom) then
                local data = utils_stpk.get_object_data(se_obj)
                if (data) then
                    data.object_flags = 31
                    data.restrictor_type = 0
                    data.shapes = {}
                    data.shapes[1] = {}
                    data.shapes[1].shtype = 0
                    data.shapes[1].offset = VEC_ZERO
                    data.shapes[1].radius = 10
                    utils_stpk.set_object_data(data, se_obj)
                end
                self:SetMsg(strformat("Spawned anomaly [%s] (%s) %s", section, se_obj.id, ext), "-")
            else
                self:SetMsg(strformat("Spawned object [%s] (%s) %s", section, se_obj.id, ext), "-")
            end
        else
            self:SetMsg(strformat("No server object made for [%s]", section), "!")
        end
    end
    item_backpack.keep_items = {}
    item_backpack.on_game_start = function()
        RegisterScriptCallback("actor_on_item_take_from_box", item_backpack.actor_on_item_take_from_box)
        RegisterScriptCallback("actor_on_item_use", item_backpack.actor_on_item_use)
        local iniafile = ini_file("items\\settings\\backpack_stash.ltx")
        item_backpack.keep_items = utils_data.collect_section(iniafile, "actor_backpack_keep_items", true)
    end
    item_backpack.actor_on_item_use = function(obj)
        if obj and (obj:section() == "itm_actor_backpack") then
            local backpack = db.actor:item_in_slot(13)
            if backpack then
                local actor = db.actor
                alife_create_awaite(function(se_obj)
                    if se_obj then
                        local txt = strformat(game.translate_string("st_itm_stash_of_character"),
                            db.actor:character_name())
                        level.map_add_object_spot_ser(se_obj.id, "treasure", txt)
                        actor_menu.set_msg(1, game.translate_string("st_stash_created"), 4)
                        local m_data = alife_storage_manager.get_state()
                        if not (m_data.player_created_stashes) then
                            m_data.player_created_stashes = {}
                        end
                        m_data.player_created_stashes[se_obj.id] = backpack:section()
                        local b_id = backpack:id()
                        alife_release_full(backpack)
                        local function transfer_items(id)
                            local obj = level.object_by_id(id)
                            if (obj) then
                                local function itr_inv(temp, item)
                                    if (item and item:id() ~= b_id and item_backpack.keep_items[item:section()] == nil) then
                                        if (IsAmmo(item) ~= true) or (is_ammo_for_wpn(item:section()) ~= true) then
                                            if (ini_sys:r_bool_ex(item:section(), "quest_item", false) == false) then
                                                if (db.actor:is_on_belt(item) == false and item_backpack.is_in_slot(item) == false) then
                                                    db.actor:transfer_item(item, obj)
                                                end
                                            end
                                        end
                                    end
                                end
                                db.actor:iterate_inventory(itr_inv)
                                return true
                            end
                            return false
                        end
                        CreateTimeEvent(0, "actor_backpack", 0, transfer_items, se_obj.id)
                    end
                end, "inv_backpack", actor:position(), actor:level_vertex_id(), actor:game_vertex_id())
            else
                actor_menu.set_msg(1, game.translate_string("st_stash_no_backpack_found"), 4)
            end
        end
    end
    item_backpack.actor_on_item_take_from_box = function(box, obj)
        if box:section() == "inv_backpack" then
            if box:is_inv_box_empty() then
                hide_hud_inventory()
                local data = {
                    stash_id = box:id(),
                    cancel = false,
                }
                SendScriptCallback("actor_on_stash_remove", data)
                if data.cancel then
                    return
                end
                local id = box:id()
                level.map_remove_object_spot(id, "treasure")
                local se_obj = alife_object(id)
                if se_obj then
                    alife_release_client(se_obj)
                end
                local m_data = alife_storage_manager.get_state()
                if (m_data.player_created_stashes and m_data.player_created_stashes[id]) then
                    local section = m_data.player_created_stashes[id]
                    alife_create_item(section, db.actor)
                    m_data.player_created_stashes[id] = nil
                end
            end
        end
    end
    item_backpack.receive_backpacks_data = function (tbl_data)
        local m_data = alife_storage_manager.get_state()
        if not m_data then return end
        if not m_data.player_created_stashes then m_data.player_created_stashes = {} end
        for k, v in pairs(tbl_data) do
            local local_id = GameManager:GetLocalIDByServerID(k)
            m_data.player_created_stashes[local_id] = v
            local obj = level.object_by_id(local_id)
            if obj then
                level.map_add_object_spot_ser(obj:id(), "treasure", "player stash")
            end
        end
    end
    item_backpack.sync_all_stashes = function (netid)
        local m_data = alife_storage_manager.get_state()
        if not m_data then return end
        GameManager:OnICustomScriptAction("item_backpack", "receive_backpacks_data", serialize_table_simple(m_data.player_created_stashes or {}), false, netid)
    end
    item_backpack.remote_stash_create = function (tbl_data)
        local txt = tbl_data[1]
        local section = tbl_data[2]
        local postbl = tbl_data[3]
        local pos = vector():set(postbl[1], postbl[2], postbl[3])
        local se_obj = alife_create("inv_backpack", pos, tbl_data[4], tbl_data[5])
        if not se_obj then return end

        local m_data = alife_storage_manager.get_state()
        if not m_data then return end
        if not m_data.player_created_stashes then m_data.player_created_stashes = {} end
        level.map_add_object_spot_ser(se_obj.id, "treasure", txt)
        -- Send callback if created stash...
        local data = {
            stash_id = se_obj.id,
            stash_name = txt,
            stash_section = section,
        }
        m_data.player_created_stashes[se_obj.id] = section
        -- SendScriptCallback
        SendScriptCallback("actor_on_stash_create", data)
        -- Sync data
        local payload = { [se_obj.id] = section }
        GameManager:OnICustomScriptAction("item_backpack", "receive_backpacks_data", serialize_table_simple(payload), false)
    end
    function item_backpack.UICreateStash:OnAccept()
        if IIsHost() then return OLDSYNCS(self) end
        local txt = self.input:GetText()
        txt = txt ~= "" and txt or strformat(game.translate_string("st_itm_stash_of_character"), db.actor:character_name())
        actor_menu.set_msg(1, game.translate_string("st_stash_created"), 4)
        local payload = { txt, self.section, db.actor:position(), db.actor:level_vertex_id(), db.actor:game_vertex_id() }
        GameManager:OnICustomScriptAction("item_backpack", "remote_stash_create", serialize_table_simple(payload), true)
        self:Close()
    end
    --BETTER to iterate the available objects
    --TO anomaly devs. WTF are you doing? in original file
    trans_outfit.transparent_gg = function()
        if not (db.actor and trans_outfit.ReadOutfitBlindnessKoeff) then return end
        local range1 = 80
        local outfit_in_slot = db.actor:item_in_slot(7)
        local koeff = outfit_in_slot and trans_outfit.ReadOutfitBlindnessKoeff(outfit_in_slot:section()) or 0
        if koeff > 0.0 then range1 = koeff end
        for _, t in pairs(db.storage) do
            if t and t.object and IsStalker(t.object) and not IsActor(t.object) then
                local dist_act_npc = db.actor:position():distance_to(t.object:position())
                if dist_act_npc <= 120 then
                    t.object:set_range(range1)
                else
                    t.object:set_range(80)
                end
            end
        end
    end
    txr_mines.sync_bomb = function (tbl)
        local local_id = GameManager:GetLocalIDByServerID(tbl[1])
        local cache_tbl = tbl[2]
        txr_mines._mines[local_id] = cache_tbl
        printf("Synced bomb data - %s", table.concat(cache_tbl, " "))
    end
    txr_mines.remote_plant_bomb = function (tbl_data)
        local EXPLOSIVE_SECTION_LOOKUP = {
            ied_rpg_new = 'rpg_new_blow',
            mine_new    = 'mine_new_blow',
            ied_new     = 'ied_new_blow'
        }
        -- Read table
        local section = tbl_data[1]
        local mode = tbl_data[2]
        local delay = tbl_data[3]
        local position_tbl = tbl_data[4]
        local LV = tbl_data[5]
        local GV = tbl_data[6]
        -- Vars that default
        local MIN_FORGET_TIME = 60 * 10
        local MAX_FORGET_TIME = 60 * 30
        local FUSE_TIME = delay or 5
        local now = txr_mines.tss()
        local spawn_pos = type(tbl_data[4]) == "userdata" and tbl_data[4] or vector():set(position_tbl[1], position_tbl[2], position_tbl[3])
        local planted_section = EXPLOSIVE_SECTION_LOOKUP[section]

        printf('plant_bomb(%s,%s,%s,%s)', section, mode, delay, planted_section)
        local se_planted = alife_create(planted_section, spawn_pos, LV, GV)
        if not se_planted then
            return false
        end
        -- Prepare cache
        local cache = {
            exp_time = now + FUSE_TIME * level.get_time_factor(),
            mode = mode,
            witnesses = {},
            active = true
        }
        -- Fill witnesses
        printf('check witnesses')
        for k, _ in pairs(db.OnlineStalkers) do
            local id = db.OnlineStalkers[k]
            local npc = level.object_by_id(id)
            if npc and IsStalker(npc) and npc:alive() then
                if npc:see(db.actor) then
                    printf('%s saw player plant %s', npc:name(), planted_se:name())
                    cache.witnesses[id] = now + math.random(MIN_FORGET_TIME, MAX_FORGET_TIME) * level.get_time_factor()
                end
            end
        end
        txr_mines._mines[se_planted.id] = cache
        GameManager:OnICustomScriptAction("txr_mines", "sync_bomb", serialize_table_simple({ se_planted.id, cache }), false)
    end
    function txr_mines.plant_bomb(obj, mode, delay)
        printf('try FX')
        local FX_BY_SECTION = {
            ied_rpg_new = 'ied_rpg',
            mine_new    = 'mine',
            ied_new     = 'ied'
        }
        -- Play animation
        local section = obj:section()
        local SFX = FX_BY_SECTION[section]
        if SFX then actor_effects.play_item_fx(SFX) end
        -- Obtaining variables
        local cd = device().cam_dir
        local ap = db.actor:position()
        local pos = vector():set(ap.x + cd.x, ap.y + 0.1, ap.z + cd.z)
        local vid = level.vertex_id(pos)
        local payload = { section, mode, delay, pos, vid, db.actor:game_vertex_id() }
        -- Remove item from backpack
        alife_release(obj)
        -- Spawn on request spawn that boombox
        if IIsHost() then return txr_mines.remote_plant_bomb(payload) end
        GameManager:OnICustomScriptAction("txr_mines", "remote_plant_bomb", serialize_table_simple(payload), true)
    end
