local function get_faction_phrases(tbl, faction)
    return tbl[faction] or tbl["default"]
end

local function on_caravan_destroyed(route_id, route)
    local dest_lvl = route.dest_level
    local eco = level_economy[dest_lvl]
    if eco then
        -- 1.6x to 2.0x inflation
        eco.price_multiplier = 1.6 + (math.random() * 0.4)
        eco.shortage_type = route.shortage_type
        eco.refreshed_stock_pending = false
    end

    local dest_disp = route.dest_level:gsub("^l%d+_", ""):gsub("^%l", string.upper)
    local phrases = get_faction_phrases(DESTROYED_PHRASES, route.faction)
    local msg = string.format(phrases[math.random(#phrases)], dest_disp, route.cargo_name)

    -- Caption is a named contact at the destination base, feel varies by faction
    local captions = {
        stalker = "Sidorovich",  dolg = "Duty Command",  ecolog = "Institute Dispatch",
        killer  = "Dushman",     bandit = "Sultan",       freedom = "Loki",
        csky    = "Clear Sky HQ",
    }
    local caption = captions[route.faction] or "Zone Trade Network"
    local sender  = { caption = caption, texture = "ui_iconsTotal_grouping" }

    if db.actor and news_manager then
        if game_relations and game_relations.is_factions_enemies then
            local actor_comm = db.actor:character_community()
            if actor_comm and not game_relations.is_factions_enemies(actor_comm, route.faction) then
                news_manager.send_tip(db.actor, msg, nil, sender, nil, nil, true)
            end
        else
            news_manager.send_tip(db.actor, msg, nil, sender, nil, nil, true)
        end
    end
end

local function on_caravan_arrived(route_id, route)
    local dest_lvl = route.dest_level
    local eco = level_economy[dest_lvl]
    if eco then
        -- 0.8x to 0.9x discount
        eco.price_multiplier = 0.8 + (math.random() * 0.1)
        eco.shortage_type = 0
        eco.refreshed_stock_pending = true
    end

    local dest_disp = route.dest_level:gsub("^l%d+_", ""):gsub("^%l", string.upper)
    local phrases = get_faction_phrases(ARRIVED_PHRASES, route.faction)
    local msg = string.format(phrases[math.random(#phrases)], dest_disp, route.cargo_name)

    local captions = {
        stalker = "Sidorovich",  dolg = "Duty Command",  ecolog = "Institute Dispatch",
        killer  = "Dushman",     bandit = "Sultan",       freedom = "Loki",
        csky    = "Clear Sky HQ",
    }
    local caption = captions[route.faction] or "Zone Trade Network"
    local sender  = { caption = caption, texture = "ui_iconsTotal_grouping" }

    if db.actor and news_manager then
        if game_relations and game_relations.is_factions_enemies then
            local actor_comm = db.actor:character_community()
            if actor_comm and not game_relations.is_factions_enemies(actor_comm, route.faction) then
                news_manager.send_tip(db.actor, msg, nil, sender, nil, nil, true)
            end
        else
            news_manager.send_tip(db.actor, msg, nil, sender, nil, nil, true)
        end
    end
end

-- ============================================================
-- A-LIFE CARAVAN SPAWNER & TRACKER (Host-Only)
-- ============================================================

-- Convert a raw smart terrain name into a human-readable location name
local function get_smart_display_name(smart_name)
    if not smart_name then return "the Zone" end
    local prefix = string.match(smart_name, "^([%a]+)_")
    return (prefix and smart_prefix_map[prefix]) or smart_name
end

-- ============================================================
-- A-LIFE CARAVAN SPAWNER & TRACKER WITH WAYPOINTS (Host-Only)
-- ============================================================

local function send_caravan_msg(msg, route)
    if not (db.actor and news_manager) then return end
    local sender = { caption = "Trade Network", texture = "ui_iconsTotal_grouping" }
    local function do_send()
        news_manager.send_tip(db.actor, msg, nil, sender, nil, nil, true)
    end
    if game_relations and game_relations.is_factions_enemies then
        local actor_comm = db.actor:character_community()
        if actor_comm and not game_relations.is_factions_enemies(actor_comm, route.faction) then
            do_send()
        end
    else
        do_send()
    end
end

-- Distress call phrases — the commander speaks in first person over the radio
local DISTRESS_PHRASES = {
    "%s here — MAYDAY! We're under attack near %s! Caravan is taking fire! Anyone close, respond!",
    "%s reporting — Ambush near %s! We have casualties! Need immediate backup!",
    "%s calling all units — heavy contact near %s! We're pinned down! Send help!",
    "%s here, we're hit near %s! Men down! If anyone can hear this — get here fast!",
    "This is %s — taking fire near %s! Caravan under attack! Respond on this frequency!",
}

local function update_caravans()
    if not IIsHost() then return end
    if not db.actor then return end
    local tg = time_global()
    
    for i, route in ipairs(ROUTES) do
        local squad_id = active_caravan_ids[i]
        
        if squad_id == 0 then
            -- No active caravan — check spawn cooldown
            if tg > (route_cooldowns[i] or 0) and math.random(100) <= 35 then
                route_cooldowns[i] = tg + math.random(240000, 480000)
                
                local src_smart = route.waypoints[1]
                local smart_src = SIMBOARD.smarts_by_names[src_smart]
                if smart_src then
                    local sq = SIMBOARD:create_squad(smart_src, route.squad_section)
                    if sq then
                        sq.scripted_target          = route.waypoints[2]
                        active_caravan_ids[i]       = sq.id
                        active_caravan_deadline[i]  = tg + route.segment_time_ms
                        active_caravan_waypoint[i]  = 2
                        
                        -- Count initial members
                        local cnt = 0
                        for _ in pairs(sq.npc_info or {}) do cnt = cnt + 1 end
                        active_caravan_npc_count[i] = cnt
                        
                        -- Departure: commander speaks in character on the radio
                        local src_disp  = route.source_level:gsub("^l%d+_", ""):gsub("^%l", string.upper)
                        local dest_disp = route.dest_level:gsub("^l%d+_", ""):gsub("^%l", string.upper)
                        local total_min = math.floor(route.segment_time_ms * (#route.waypoints - 1) / 60000)

                        -- Try to get the commander's actual name from the server object
                        local cmdr_name = route.name
                        pcall(function()
                            local cmdr_id = sq:commander_id()
                            local cmdr_se = cmdr_id and alife_object(cmdr_id)
                            if cmdr_se then
                                local n = cmdr_se:character_name()
                                if n and n ~= "" then cmdr_name = n end
                            end
                        end)

                        local DEPARTURE_PHRASES = {
                            stalker = {
                                "%s here. We're moving out from %s, headed to %s. Carrying %s. Should be there in roughly %d minutes — Zone permitting.",
                                "%s, rolling out. %s to %s, hauling %s. ETA around %d minutes. Keep the channel clear.",
                                "This is %s. Leaving %s now en route to %s with a full load of %s. See you in about %d minutes.",
                            },
                            dolg = {
                                "%s reporting. Tactical convoy departing %s for %s. Manifest: %s. Arrival in approximately %d minutes. Duty moves.",
                                "Column leader %s. We roll from %s to %s. Cargo: %s. ETA %d minutes. Stay sharp out there.",
                                "%s, convoy command. Departing %s for %s with %s. %d-minute estimate. Duty never sleeps.",
                            },
                            ecolog = {
                                "%s, field liaison. Convoy departing %s en route to %s with %s. ETA approximately %d minutes.",
                                "Institute convoy led by %s is underway from %s en route to %s. Cargo: %s. ETA %d minutes.",
                            },
                            killer = {
                                "%s. Package moving from %s to %s. Contents: %s. ETA %d minutes. Don't ask questions.",
                                "%s here. Shipment is rolling. %s to %s, carrying %s. %d minutes. Keep comms clean.",
                            },
                            bandit = {
                                "Ey, %s here! We're hauling outta %s, heading to %s with a stack of %s. Should roll in about %d minutes — if no one messes with us.",
                                "%s on the line. Boys are moving from %s to %s. Got %s loaded up. %d minutes, give or take. Don't try anything stupid.",
                            },
                            freedom = {
                                "%s, rolling free! Heading from %s to %s with %s aboard. Should be there in about %d minutes, brother. Zone's open — let's use it.",
                                "Freedom convoy, %s speaking. We're leaving %s, bound for %s. %s on board. %d minutes roughly. Stay free.",
                            },
                            csky = {
                                "%s, Clear Sky convoy lead. Departing %s for %s. Cargo: %s. Estimated arrival in %d minutes.",
                                "Clear Sky field team — %s here. Moving from %s to %s with %s. ETA: %d minutes. Zone activity monitored.",
                            },
                        }
                        local d_phrases = DEPARTURE_PHRASES[route.faction] or {
                            "%s departing %s for %s with %s. ETA %d minutes."
                        }
                        local d_phrase = d_phrases[math.random(#d_phrases)]
                        local dep_msg = string.format(d_phrase, cmdr_name, src_disp, dest_disp, route.cargo_name, total_min)

                        local sender = { caption = cmdr_name, texture = "ui_iconsTotal_grouping" }
                        if db.actor and news_manager then
                            if game_relations and game_relations.is_factions_enemies then
                                local actor_comm = db.actor:character_community()
                                if actor_comm and not game_relations.is_factions_enemies(actor_comm, route.faction) then
                                    news_manager.send_tip(db.actor, dep_msg, nil, sender, nil, nil, true)
                                end
                            else
                                news_manager.send_tip(db.actor, dep_msg, nil, sender, nil, nil, true)
                            end
                        end
                    end
                end
            end
            
        else
            -- Active caravan — check if still alive
            local se_squad = alife_object(squad_id)
            if not se_squad then
                -- Wiped out en route
                active_caravan_ids[i]       = 0
                active_caravan_deadline[i]  = 0
                active_caravan_waypoint[i]  = 2
                active_caravan_npc_count[i] = 0
                on_caravan_destroyed(i, route)
            else
                -- ==== CASUALTY DETECTION — distress call ====
                local cur_count = 0
                for _ in pairs(se_squad.npc_info or {}) do cur_count = cur_count + 1 end
                
                local prev_count = active_caravan_npc_count[i]
                if prev_count > 0 and cur_count < prev_count then
                    -- Someone was killed — commander broadcasts distress call
                    local loc = get_location_near(se_squad.position)
                    
                    -- Try to get the commander's character name
                    local cmdr_name = route.name  -- fallback
                    pcall(function()
                        local cmdr_id = se_squad:commander_id()
                        local cmdr_se = cmdr_id and alife_object(cmdr_id)
                        if cmdr_se then
                            local n = cmdr_se:character_name()
                            if n and n ~= "" then cmdr_name = n end
                        end
                    end)
                    
                    local phrase = DISTRESS_PHRASES[math.random(#DISTRESS_PHRASES)]
                    local msg    = string.format(phrase, cmdr_name, loc)
                    
                    -- Distress call goes to ALL friendly players (no faction filter — it's a radio broadcast)
                    if db.actor and news_manager then
                        local sender = { caption = "DISTRESS CALL", texture = "ui_iconsTotal_radiation" }
                        news_manager.send_tip(db.actor, msg, nil, sender, nil, nil, true)
                        pcall(dispatch_distress_responders, se_squad)
                    end
                end
                active_caravan_npc_count[i] = cur_count
                
                -- ==== WAYPOINT PROGRESSION (silent) ====
                if tg >= (active_caravan_deadline[i] or 0) then
                    local wp_idx = active_caravan_waypoint[i]
                    
                    if wp_idx >= #route.waypoints then
                        -- All waypoints done — final destination reached
                        active_caravan_ids[i]       = 0
                        active_caravan_deadline[i]  = 0
                        active_caravan_waypoint[i]  = 2
                        active_caravan_npc_count[i] = 0
                        on_caravan_arrived(i, route)
                        pcall(function() SIMBOARD:remove_squad(se_squad) end)
                    else
                        -- Silent advance to next waypoint
                        local next_wp = route.waypoints[wp_idx + 1]
                        se_squad.scripted_target   = next_wp
                        active_caravan_waypoint[i] = wp_idx + 1
                        active_caravan_deadline[i] = tg + route.segment_time_ms
                    end
                end
                -- else: mid-segment, squad alive — nothing to do
            end
        end
    end
end

-- ============================================================
-- MONKEY-PATCHING: trade_manager PRICE DYNAMIC SCALING
-- ============================================================

local orig_get_buy_discount = nil
local orig_get_sell_discount = nil

local function patch_trade_manager()
    if not trade_manager then return end
    
    if not orig_get_buy_discount then
        orig_get_buy_discount = trade_manager.get_buy_discount
        trade_manager.get_buy_discount = function(npc_id)
            local base = orig_get_buy_discount(npc_id) or 1.0
            local npc = level.object_by_id(npc_id)
            if npc then
                local ln = level.name()
                local eco = ln and level_economy[ln]
                if eco then
                    -- Trader Buy: what trader pays to buy from the player.
                    -- Scale DOWN what trader pays if level has shortages/inflation.
                    local mod = 1.0 / eco.price_multiplier
                    return base * mod
                end
            end
            return base
        end
    end
    
    if not orig_get_sell_discount then
        orig_get_sell_discount = trade_manager.get_sell_discount
        trade_manager.get_sell_discount = function(npc_id)
            local base = orig_get_sell_discount(npc_id) or 1.0
            local npc = level.object_by_id(npc_id)
            if npc then
                local ln = level.name()
                local eco = ln and level_economy[ln]
                if eco then
                    -- Trader Sell: what player pays to buy from the trader.
                    -- Scale UP what player pays during shortages/inflation.
                    return base * eco.price_multiplier
                end
            end
            return base
        end
    end
end

-- ============================================================
-- PHYSICAL INVENTORY STOCK MANAGEMENT (Shortages & Refreshes)
-- ============================================================

local function on_gui_show(gui_name)
    if gui_name ~= "UITrade" and gui_name ~= "Trade" and gui_name ~= "Dialog" then return end
    
    local npc = mob_trade and mob_trade.GetTalkingNpc()
    if not npc or npc:character_community() ~= "trader" then return end
    
    local ln = level.name()
    local eco = ln and level_economy[ln]
    if not eco then return end
    
    -- A) Shortage physical sweep: Delete scarce categories
    if eco.shortage_type > 0 then
        npc:iterate_inventory(function(owner, item)
            local sec = item:section()
            local should_purge = false
            
            if eco.shortage_type == 1 or eco.shortage_type == 3 then
                -- Delete ammunition
                if string.find(sec, "^ammo_") then
                    should_purge = true
                end
            end
            
            if eco.shortage_type == 2 or eco.shortage_type == 3 then
                -- Delete medkits & bandages
                if sec == "medkit" or sec == "medkit_army" or sec == "medkit_scientic" or sec == "bandage" then
                    should_purge = true
                end
            end
            
            if should_purge then
                local se_obj = alife_object(item:id())
                if se_obj then
                    pcall(function()
                        alife():release(se_obj, true)
                    end)
                end
            end
        end, npc)
    end
    
    -- B) Arrival physical inject: Spawn premium stock once
    if eco.refreshed_stock_pending then
        eco.refreshed_stock_pending = false
        
        local premium_spawns = {
            "medkit_army", "medkit_army",
            "ammo_5.45x39_ap", "ammo_5.45x39_ap",
            "ammo_5.56x45_ap", "ammo_5.56x45_ap",
            "af_cristall_flower" -- rare artifact
        }
        
        local pos = npc:position()
        local lv = npc:level_vertex_id()
        local gv = npc:game_vertex_id()
        local npc_id = npc:id()
        
        for _, sec in ipairs(premium_spawns) do
            pcall(function()
                alife():create(sec, pos, lv, gv, npc_id)
            end)
        end
    end
end

-- ============================================================
-- GRASSROOTS CLOSED-LOOP NPC TRADE SIMULATION
-- ============================================================

local function get_default_section(cat)
    return ESSENTIAL_ITEMS[cat][1]
end

local function scan_npc_inventory(npc)
    local counts = { heal = 0, bandage = 0, food = 0, drink = 0, medicine = 0, cigarette = 0 }
    -- Track all excess items per category to sell off
    local excess_items = { heal = {}, bandage = {}, food = {}, drink = {}, medicine = {}, cigarette = {} }
    local sellable_loot = {}

    npc:iterate_inventory(function(owner, item)
        local sec = item:section()
        local is_essential = false

        for cat, list in pairs(ESSENTIAL_ITEMS) do
            for _, s in ipairs(list) do
                if sec == s then
                    is_essential = true
                    counts[cat] = (counts[cat] or 0) + 1
                    -- If already have 1, this is excess — mark for selling
                    if counts[cat] > 1 then
                        table.insert(excess_items[cat], item)
                    end
                    break
                end
            end
            if is_essential then break end
        end

        if not is_essential then
            -- Collect monster parts, weapon scrap, secondary firearms to sell
            if string.find(sec, "^mutant_part_") or string.find(sec, "^part_") or string.find(sec, "^wpn_") or string.find(sec, "^itm_") then
                table.insert(sellable_loot, item)
            end
        end
    end, npc)

    return counts, sellable_loot, excess_items
end

local function get_nearest_trader(npc)
    local pos = npc:position()
    local nearest = nil
    local min_dist = 50 -- within 50 metres
    
    for id, st in pairs(db.storage) do
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and obj:character_community() == "trader" then
            local dist = pos:distance_to(obj:position())
            if dist < min_dist then
                min_dist = dist
                nearest = obj
            end
        end
    end
    return nearest
end

local function run_npc_grassroots_trade()
    if not IIsHost() then return end
    
    local stalkers = {}
    for id, st in pairs(db.storage) do
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive() and id ~= AC_ID and obj:character_community() ~= "trader"
           and get_object_story_id(id) == nil then
            local squad = get_object_squad(obj)
            if squad then
                local is_sim = get_object_story_id(squad.id) == nil
                if is_sim then
                    local sec = squad:section_name()
                    if sec and (string.find(sec, "sim_squad") or string.find(sec, "simulation") or string.find(sec, "_sim_")) then
                        table.insert(stalkers, obj)
                    end
                end
            end
        end
    end
    
    if #stalkers == 0 then return end
    
    -- Process a small, randomized subset of stalkers each tick to preserve CPU cycles
    local count = math.min(3, #stalkers)
    for k = 1, count do
        local npc = stalkers[math.random(#stalkers)]
        local npc_name = npc:character_name() or "Stalker"
        local counts, loot = scan_npc_inventory(npc)
        local trader = get_nearest_trader(npc)
        
        -- A) Scavenger/Loot Selling loop: Sell trophies to Trader to earn Rubles
        if trader and #loot > 0 then
            local total_earned = 0
            
            -- Apply personality weight: Scavengers and Merchants are much more active
            local personality = load_var(npc, "alife_personality") or "Survivor"
            local sell_chance = 40
            if personality == "Scavenger" or personality == "Merchant" then
                sell_chance = 85
            end
            
            if math.random(100) <= sell_chance then
                for _, item in ipairs(loot) do
                    local sec = item:section()
                    local cost = system_ini():r_float(sec, "cost") or 200
                    
                    local ln = level.name()
                    local eco = ln and level_economy[ln]
                    local multiplier = eco and (1.0 / eco.price_multiplier) or 1.0
                    local price = math.floor(cost * 0.25 * multiplier) -- sell loot at 25% value scaled
                    
                    pcall(function()
                        npc:transfer_item(item, trader)
                        npc:give_money(price)
                        total_earned = total_earned + price
                    end)
                end
            end
        end
        
        -- Re-scan inventory post-sales to get actual survival counts
        counts, loot, excess_items = scan_npc_inventory(npc)

        -- A2) Excess essential item sell-off: keep exactly 1 per category
        if trader then
            for cat, items_list in pairs(excess_items) do
                for _, item_obj in ipairs(items_list) do
                    local sec = item_obj:section()
                    local cost = system_ini():r_float(sec, "cost") or 150
                    local price = math.floor(cost * 0.4) -- sell excess at 40%
                    pcall(function()
                        npc:transfer_item(item_obj, trader)
                        npc:give_money(price)
                    end)
                end
            end
            -- Re-scan after excess sell
            counts, loot, excess_items = scan_npc_inventory(npc)
        end
        
        -- B) Survival Purchase loop: Buy necessities from base Trader using earned Rubles
        if trader then
            for cat, cnt in pairs(counts) do
                if cnt == 0 then
                    local buy_sec = get_default_section(cat)
                    local trader_item = nil
                    
                    trader:iterate_inventory(function(owner, item)
                        if item:section() == buy_sec then
                            trader_item = item
                        end
                    end, trader)
                    
                    if trader_item then
                        local cost = system_ini():r_float(buy_sec, "cost") or 300
                        local ln = level.name()
                        local eco = ln and level_economy[ln]
                        local multiplier = eco and eco.price_multiplier or 1.0
                        local final_price = math.floor(cost * multiplier)
                        
                        if npc:money() >= final_price then
                            pcall(function()
                                trader:transfer_item(trader_item, npc)
                                npc:give_money(-final_price)
                                trader:give_money(final_price)
                            end)
                            
                            -- Verify if this was the last item of this section in trader inventory
                            local has_more = false
                            trader:iterate_inventory(function(owner, item)
                                if item:section() == buy_sec then
                                    has_more = true
                                end
                            end, trader)
                            
                            -- Fire "last item" alert only — NPC speaks in character to the radio channel
                            if not has_more and npc:relation(db.actor) ~= game_object.enemy then
                                local tr_name = trader:character_name() or "Trader"
                                local item_disp = game.translate_string(buy_sec)
                                local loc_name = get_location_near(npc:position())
                                
                                local phrases = {
                                    "Heads up — just bought the last %s from %s here in %s. Nothing left.",
                                    "FYI guys, %s at %s in %s is completely out of %s. Don't bother.",
                                    "Yo, grabbed the last %s off %s in %s. Stock's gone.",
                                    "Worth knowing — %s ran dry on %s over in %s.",
                                    "Just cleaned out %s's last %s in %s. Supply's done.",
                                }
                                local msg
                                local idx = math.random(#phrases)
                                if idx == 2 then
                                    -- special order: item, trader, location
                                    msg = string.format(phrases[idx], item_disp, tr_name, loc_name, item_disp)
                                else
                                    msg = string.format(phrases[idx], item_disp, tr_name, loc_name)
                                end
                                
                                local sender = {
                                    caption = npc_name,
                                    texture = npc:character_icon() or "ui_iconsTotal_grouping",
                                }
                                CreateTimeEvent(0, "npc_last_buy_" .. npc:id() .. "_" .. time_global(), math.random(1, 3), function()
                                    news_manager.send_tip(db.actor, msg, nil, sender, nil, nil, true)
                                    return true
                                end)
                            end
                            break -- buy one item type per cycle
                        end
                    end
                end
            end
        end
        
        -- C) Campfire peer-to-peer barter (if far from traders)
        if not trader then
            local peers = {}
            local pos = npc:position()
            for id, st in pairs(db.storage) do
                local obj = level.object_by_id(id)
                if obj and IsStalker(obj) and obj:alive() and id ~= AC_ID and id ~= npc:id() and obj:character_community() ~= "trader" then
                    if npc:relation(obj) ~= game_object.enemy then
                        local dist = pos:distance_to(obj:position())
                        if dist < 12 then -- campfire range
                            table.insert(peers, obj)
                        end
                    end
                end
            end
            
            if #peers > 0 then
                for cat, cnt in pairs(counts) do
                    if cnt == 0 then
                        for _, peer in ipairs(peers) do
                            local p_counts, p_loot, p_excess = scan_npc_inventory(peer)
                            if (p_counts[cat] or 0) > 1 then
                                local trade_sec = get_default_section(cat)
                                local item_obj = nil
                                
                                peer:iterate_inventory(function(owner, item)
                                    if item:section() == trade_sec then
                                        item_obj = item
                                    end
                                end, peer)
                                
                                if item_obj then
                                    local cost = system_ini():r_float(trade_sec, "cost") or 300
                                    local price = math.floor(cost * 0.85) -- peer trade at 85% cost
                                    
                                    if npc:money() >= price then
                                        pcall(function()
                                            peer:transfer_item(item_obj, npc)
                                            npc:give_money(-price)
                                            peer:give_money(price)
                                        end)
                                        
                                        -- (no ambient message for peer barter — silent transaction)
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end

-- ============================================================
-- MODULE REGISTER & CALLBACKS
-- ============================================================

local last_trade_time  = 0
local last_hazard_time = 0
local TRADE_COOLDOWN   = 12000  -- 12 s: caravans + grassroots trade
local HAZARD_COOLDOWN  = 3000   --  3 s: radiation / anomaly / item-use simulation

local function on_actor_update()
    if not IIsHost() then return end
    local tg = time_global()

    -- Economy & trade tick (slow)
    if tg > last_trade_time + TRADE_COOLDOWN then
        last_trade_time = tg
        update_caravans()
        run_npc_grassroots_trade()
    end

    -- Hazard simulation tick (fast — radiation, anomalies, item use)
    if tg > last_hazard_time + HAZARD_COOLDOWN then
        last_hazard_time = tg
        run_npc_hazard_simulation()
    end
end

function on_game_start()
    if _G.M_SUPPLY_CARAVANS_REGISTERED then return end
    _G.M_SUPPLY_CARAVANS_REGISTERED = true
    
    RegisterScriptCallback("actor_on_update",  on_actor_update)
    RegisterScriptCallback("actor_on_save",    actor_on_save)
    RegisterScriptCallback("actor_on_load",    actor_on_load)
    RegisterScriptCallback("GUI_on_show",      on_gui_show)
    
    -- Intercept trade manager calculations
    patch_trade_manager()
end
