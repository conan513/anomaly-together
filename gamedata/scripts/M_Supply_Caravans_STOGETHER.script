-- ============================================================
-- GAZDASÁGI ÁLLAPOT TÁBLA (ECONOMY STATE TABLE)
-- ============================================================

local level_economy = {}
local route_cooldowns         = {0, 0, 0, 0, 0, 0, 0, 0}
local active_caravan_ids      = {0, 0, 0, 0, 0, 0, 0, 0}
local active_caravan_deadline = {0, 0, 0, 0, 0, 0, 0, 0}  -- tg deadline for current segment
local active_caravan_waypoint = {2, 2, 2, 2, 2, 2, 2, 2}  -- index of current destination waypoint
local active_caravan_npc_count= {0, 0, 0, 0, 0, 0, 0, 0}  -- last known member count (for casualty detection)

-- Initialize starting values
for _, lvl in ipairs(ECONOMY_LEVELS) do
    level_economy[lvl] = {
        price_multiplier = 1.0,
        shortage_type = 0, -- 0=none, 1=ammo, 2=meds, 3=all
        refreshed_stock_pending = false
    }
end

-- ============================================================
-- PERSISTENCE: actor_on_save / actor_on_load PACKET I/O
-- ============================================================

local function actor_on_save(packet)
    if not packet then return end
    packet:w_u8(3)  -- version 3: waypoints + remaining segment time
    
    for _, lvl in ipairs(ECONOMY_LEVELS) do
        local eco = level_economy[lvl] or { price_multiplier = 1.0, shortage_type = 0, refreshed_stock_pending = false }
        packet:w_float(eco.price_multiplier)
        packet:w_u8(eco.shortage_type)
        packet:w_bool(eco.refreshed_stock_pending)
    end
    
    local tg = time_global()
    for i = 1, 8 do
        packet:w_u32(route_cooldowns[i] or 0)
        packet:w_u32(active_caravan_ids[i] or 0)
        -- Store remaining ms in current segment (safe across save/load)
        local remaining = math.max(0, (active_caravan_deadline[i] or 0) - tg)
        packet:w_u32(remaining)
        packet:w_u8(active_caravan_waypoint[i] or 2)
    end
end

local function actor_on_load(reader)
    if not reader then return end
    local version = reader:r_u8()
    if not version then return end
    
    for _, lvl in ipairs(ECONOMY_LEVELS) do
        local mult = reader:r_float() or 1.0
        local sh   = reader:r_u8()   or 0
        local ref  = reader:r_bool() or false
        level_economy[lvl] = { price_multiplier = mult, shortage_type = sh, refreshed_stock_pending = ref }
    end
    
    local tg = time_global()
    for i = 1, 8 do
        route_cooldowns[i]    = reader:r_u32() or 0
        active_caravan_ids[i] = reader:r_u32() or 0
        
        if version >= 3 then
            local remaining = reader:r_u32() or 0
            -- Reconstruct absolute deadline from remaining time
            active_caravan_deadline[i] = (remaining > 0) and (tg + remaining) or 0
            active_caravan_waypoint[i] = reader:r_u8() or 2
        elseif version >= 2 then
            reader:r_u32()  -- skip old spawn_time field (v2)
            active_caravan_deadline[i] = 0
            active_caravan_waypoint[i] = 2
        end
    end
end

-- ============================================================
-- LOCAL LOCATION NAME PARSER HELPER
-- ============================================================

local smart_prefix_map = {
    esc = "Cordon",          gar = "Garbage",       agr = "Agroprom",
    val = "Dark Valley",     bar = "Rostok",         yan = "Yantar",
    mil = "Army Warehouses", rad = "Radar",          lim = "Limansk",
    pri = "Pripyat",         cit = "Dead City",      red = "Red Forest",
    jup = "Jupiter",         zat = "Zaton",          mar = "Great Swamps",
    ds  = "Darkscape",       trc = "Truck Cemetery",
}

local function get_location_near(pos)
    if not pos then return "the Zone" end
    local nearest = nil
    local min_dist = 999999
    for _, smart in pairs(db.smart_terrain_by_id or {}) do
        if smart.position then
            local d = pos:distance_to(smart.position)
            if d < min_dist then
                min_dist = d
                local raw = smart:name()
                if raw then
                    local prefix = string.match(raw, "^([%a%d]+)_")
                    if prefix and smart_prefix_map[prefix] then
                        nearest = smart_prefix_map[prefix]
                    elseif level and level.name then
                        local ln = level.name()
                        nearest = ln and ln:gsub("^l%d+_", ""):gsub("^%l", string.upper) or "the Zone"
                    end
                end
            end
        end
    end
    return nearest or (level and level.name and level.name() or "the Zone")
end

local function get_nearest_smart_at_pos(pos)
    if not pos then return nil end
    local nearest = nil
    local min_dist = 999999
    for id, smart in pairs(db.smart_terrain_by_id or {}) do
        if smart.position then
            local d = pos:distance_to(smart.position)
            if d < min_dist then
                min_dist = d
                nearest = smart
            end
        end
    end
    return nearest
end

local function dispatch_distress_responders(caravan_squad)
    if not (caravan_squad and caravan_squad.position) then return end
    
    local nearest_smart = get_nearest_smart_at_pos(caravan_squad.position)
    if not nearest_smart then return end
    
    local sim = alife()
    local gg = game_graph()
    local caravan_pos = caravan_squad.position
    local caravan_faction = caravan_squad.player_id or "stalker"
    
    local caravan_level = sim:level_name(gg:vertex(caravan_squad.m_game_vertex_id):level_id())
    
    for squad_id, _ in pairs(SIMBOARD.squads) do
        if squad_id ~= caravan_squad.id then
            local squad = sim:object(squad_id)
            if squad and squad:npc_count() > 0 then
                -- Check if squad is busy on a previous distress response or other scripted task
                local is_busy = false
                local distress_target = se_load_var(squad.id, nil, "distress_target")
                if distress_target then
                    local target_smart = SIMBOARD.smarts_by_names[distress_target]
                    if target_smart and target_smart.position then
                        local dist_to_target = squad.position:distance_to(target_smart.position)
                        if dist_to_target < 40 then
                            -- Arrived at target! Clear distress status
                            se_save_var(squad.id, nil, "distress_target", nil)
                            squad.scripted_target = nil
                        else
                            local last_time = se_load_var(squad.id, nil, "distress_time") or 0
                            local tg = time_global()
                            if tg < last_time + 300000 then -- 5 min limit
                                is_busy = true
                            else
                                -- Timeout, release
                                se_save_var(squad.id, nil, "distress_target", nil)
                                squad.scripted_target = nil
                            end
                        end
                    else
                        se_save_var(squad.id, nil, "distress_target", nil)
                    end
                end

                -- Check if they are on some other official quest/script task
                if not is_busy then
                    if squad.get_script_target and squad:get_script_target() then
                        is_busy = true
                    elseif squad.scripted_target and squad.scripted_target ~= "" then
                        if not distress_target or squad.scripted_target ~= distress_target then
                            is_busy = true
                        end
                    end
                end

                if not is_busy then
                    -- Check level
                    local squad_level = sim:level_name(gg:vertex(squad.m_game_vertex_id):level_id())
                    if caravan_level == squad_level then
                        -- Check if squad is player's companion squad
                        local is_safe = not (axr_companions and axr_companions.companion_squads and axr_companions.companion_squads[squad_id])
                        if is_safe then
                            if get_object_story_id(squad.id) ~= nil then is_safe = false end
                            local sec = squad:section_name()
                            if is_safe and sec and not (string.find(sec, "sim_squad") or string.find(sec, "simulation") or string.find(sec, "_sim_")) then
                                is_safe = false
                            end
                            if is_safe and (squad.player_id == "trader") then
                                is_safe = false
                            end
                        end
                        if is_safe then
                            -- Check if squad is human (stalker) and not monster
                            if not (is_squad_monster and is_squad_monster[squad.player_id]) then
                                -- Check relations: not enemy to caravan faction
                                local is_enemy = false
                                if game_relations and game_relations.is_factions_enemies then
                                    is_enemy = game_relations.is_factions_enemies(squad.player_id, caravan_faction)
                                end
                                
                                if not is_enemy then
                                    -- Check distance
                                    local dist = squad.position:distance_to(caravan_pos)
                                    if dist <= 350 then -- 350 meters
                                        local cmdr_id = squad:commander_id()
                                        local cmdr_obj = level.object_by_id(cmdr_id)
                                        if cmdr_obj and cmdr_obj:alive() and cmdr_obj:character_community() ~= "trader" and get_object_story_id(cmdr_id) == nil then
                                            -- Check relation with player
                                            if db.actor and cmdr_obj:relation(db.actor) ~= game_object.enemy then
                                                -- Load personality
                                                local personality = load_var(cmdr_obj, "alife_personality")
                                                if not personality then
                                                    local pers_list = {"Scavenger", "Aggressor", "Survivor", "Coward", "Enforcer", "Merchant"}
                                                    personality = pers_list[math.random(#pers_list)]
                                                    save_var(cmdr_obj, "alife_personality", personality)
                                                end
                                                
                                                if personality == "Enforcer" or personality == "Aggressor" or personality == "Scavenger" then
                                                    -- Save distress response status
                                                    se_save_var(squad.id, nil, "distress_target", nearest_smart:name())
                                                    se_save_var(squad.id, nil, "distress_time", time_global())

                                                    -- Redirect squad to nearest smart terrain to the caravan
                                                    if xsquad and xsquad.acquire_squad then
                                                        pcall(function()
                                                            xsquad.acquire_squad(squad, nearest_smart, true)
                                                        end)
                                                    else
                                                        squad.scripted_target = nearest_smart:name()
                                                    end
                                                
                                                -- Send a radio response message on the PDA with 40% chance
                                                if math.random(100) <= 40 then
                                                    local phrase = ""
                                                    local cmdr_name = cmdr_obj:character_name() or "Stalker"
                                                    local loc_name = get_location_near(caravan_pos)
                                                    
                                                    if personality == "Enforcer" then
                                                        phrase = string.format("This is %s. Hang on, we hear you! Squad is moving in to support at %s!", cmdr_name, loc_name)
                                                    elseif personality == "Aggressor" then
                                                        phrase = string.format("Finally, some action. %s here, we are heading to %s to help wipe them out!", cmdr_name, loc_name)
                                                    elseif personality == "Scavenger" then
                                                        phrase = string.format("Heard the distress call from %s. We are close, moving to the sector now!", cmdr_name, loc_name)
                                                    end
                                                    
                                                    if phrase ~= "" and db.actor and news_manager then
                                                        local comm = cmdr_obj:character_community() or ""
                                                        local comm_name = (comm ~= "") and game.translate_string(comm) or ""
                                                        local caption = cmdr_name
                                                        if comm_name ~= "" then
                                                            caption = caption .. " (" .. comm_name .. ")"
                                                        end
                                                        local sender = { caption = caption, texture = cmdr_obj:character_icon() or "ui_iconsTotal_grouping" }
                                                        
                                                        CreateTimeEvent(0, "responder_msg_" .. squad_id, math.random(2, 4), function()
                                                            news_manager.send_tip(db.actor, phrase, nil, sender, nil, nil, true)
                                                            return true
                                                        end)
                                                    end
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end
end


-- ============================================================
-- NPC HAZARD SIMULATION HELPERS
-- ============================================================

-- Read highest radiation_protection value from NPC's equipped suit
local function get_npc_rad_protection(npc)
    local best = 0
    local ini  = system_ini()
    npc:iterate_inventory(function(owner, item)
        local sec = item:section()
        if ini:section_exist(sec) and ini:line_exist(sec, "radiation_protection") then
            local v = ini:r_float(sec, "radiation_protection") or 0
            if v > best then best = v end
        end
    end, npc)
    return best
end

-- Try to make an NPC use the first found item matching any of the given sections
local function npc_use_item_section(npc, sections)
    local used = false
    npc:iterate_inventory(function(owner, item)
        if used then return end
        for _, sec in ipairs(sections) do
            if item:section() == sec then
                pcall(function() npc:use_item(item) end)
                used = true
                return
            end
        end
    end, npc)
    return used
end

-- Set squad's scripted_target to the nearest safe smart terrain so the squad flees
local function flee_squad_to_nearest_safe(npc)
    local se_npc = alife_object(npc:id())
    if not se_npc then return end
    local squad = alife_object(se_npc.group_id)
    if not squad then return end

    -- Exclude traders, story/quest NPCs/squads, and non-simulation squads
    local is_safe = (npc:character_community() ~= "trader") and (get_object_story_id(npc:id()) == nil)
    if is_safe and squad then
        if get_object_story_id(squad.id) ~= nil then is_safe = false end
        local sec = squad:section_name()
        if is_safe and sec and not (string.find(sec, "sim_squad") or string.find(sec, "simulation") or string.find(sec, "_sim_")) then
            is_safe = false
        end
    else
        is_safe = false
    end
    if not is_safe then return end

    local best_name = nil
    local best_dist = 9999
    local pos = npc:position()
    for name, smart in pairs(SIMBOARD.smarts_by_names or {}) do
        if smart and smart.position then
            local d = pos:distance_to(smart.position)
            -- Must be at least 20 m away (so we actually move AWAY from danger)
            if d > 20 and d < best_dist then
                best_dist = d
                best_name = name
            end
        end
    end
    if best_name then
        squad.scripted_target = best_name
        se_save_var(squad.id, nil, "distress_target", best_name)
        se_save_var(squad.id, nil, "distress_time", time_global())
    end
end

-- Previous health snapshot table used to detect rapid health drops (anomaly hits)
local npc_prev_hp = {}

-- Main hazard update: radiation damage, antirad/cigarette use, anomaly flee
local function run_npc_hazard_simulation()
    if not IIsHost() then return end

    local stalkers = {}
    for id, _ in pairs(db.storage) do
        local obj = level.object_by_id(id)
        if obj and IsStalker(obj) and obj:alive()
           and id ~= AC_ID
           and obj:character_community() ~= "trader"
           and get_object_story_id(id) == nil then
            local squad = get_object_squad(obj)
            if squad and get_object_story_id(squad.id) == nil then
                local sec = squad:section_name()
                if sec and (string.find(sec, "sim_squad") or string.find(sec, "simulation") or string.find(sec, "_sim_")) then
                    table.insert(stalkers, obj)
                end
            end
        end
    end
    if #stalkers == 0 then return end

    -- Process a small random subset every tick for CPU budget
    local count = math.min(6, #stalkers)
    for _ = 1, count do
        local npc    = stalkers[math.random(#stalkers)]
        local npc_id = npc:id()
        local hp     = npc.health

        -- ==== RADIATION ====
        local rad = npc.radiation
        if rad > 0.08 then
            local rad_prot = get_npc_rad_protection(npc)
            local eff_rad  = rad * math.max(0.0, 1.0 - rad_prot)

            -- Scale damage: full suit (1.0 protection) → no damage; bare skin (0.0) → full damage
            if eff_rad > 0.04 then
                pcall(function()
                    npc:change_health(-(eff_rad * 0.005))
                end)
            end

            -- Use antirad when radiation is noticeable
            if eff_rad > 0.18 then
                npc_use_item_section(npc, { "antirad" })
            end

            -- Flee from critical radiation zone
            if eff_rad > 0.45 then
                flee_squad_to_nearest_safe(npc)
            end
        end

        -- ==== PSY / CIGARETTE ====
        -- npc.psy_health may not exist on all builds, wrap defensively
        pcall(function()
            local psy = npc.psy_health
            if psy and psy < 0.35 then
                -- cigarette first (mild), then psy blocker (stronger)
                if not npc_use_item_section(npc, { "cigarettes", "cigarettes_lucky", "cigarettes_russian" }) then
                    npc_use_item_section(npc, { "drug_psy_blockade" })
                end
            end
        end)

        -- ==== ANOMALY ZONE DETECTION (rapid health loss without radiation) ====
        local prev_hp = npc_prev_hp[npc_id]
        if prev_hp then
            -- More than 4 % health lost in one 3-second tick from a non-radiation source
            -- → NPC is inside an anomaly field; make them flee immediately
            if (hp - prev_hp) < -0.04 and rad < 0.08 then
                flee_squad_to_nearest_safe(npc)
                -- Emergency heal if critical
                if hp < 0.25 then
                    npc_use_item_section(npc, { "medkit_army", "medkit", "medkit_scientic" })
                end
            end
        end
        npc_prev_hp[npc_id] = hp

        -- ==== PASSIVE LOW-HEALTH MEDKIT USE ====
        if hp < 0.30 then
            npc_use_item_section(npc, { "medkit_army", "medkit", "medkit_scientic" })
        end
    end
end

