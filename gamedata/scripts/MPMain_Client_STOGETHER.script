    RegisterPatch(state_mgr.evaluator_state_mgr_idle_alife, "evaluate", RETURN_FALSE)

    RegisterPatch(utils_obj, "try_to_strafe", function (npc, old_vid)
        return utils_obj.lmove(npc, old_vid, old_vid)
    end)
    RegisterPatch(utils_obj, "try_go_aside_object", function (npc, old_vid)
        return utils_obj.lmove(npc, old_vid, old_vid)
    end)
    RegisterPatch(utils_obj, "try_go_backward", function (npc, old_vid)
        return utils_obj.lmove(npc, old_vid, old_vid)
    end)

    RegisterPatch(state_mgr.state_manager, "update", NOP)
    RegisterPatch(move_mgr.move_mgr, "update", NOP)
    RegisterPatch(move_mgr.move_mgr, "initialize", function(self, npc)
        self.__disable = true
    end)

    RegisterPatch(dynamic_news_manager.DynamicNewsManager, "TickRandom", RETURN_TRUE)
    RegisterPatch(dynamic_news_manager.DynamicNewsManager, "WelcomeToNetwork", NOP)
    RegisterPatch(release_body_manager.Crelease_body, "clear", NOP)
    RegisterPatch(xr_combat_ignore, "is_enemy", RETURN_FALSE)
end