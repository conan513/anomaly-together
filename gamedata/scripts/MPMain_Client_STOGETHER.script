    RegisterPatch(state_mgr_animstate.eva_state_mgr_animstate, "evaluate", RETURN_FALSE)
    RegisterPatch(state_mgr_bodystate.eva_state_mgr_bodystate, "evaluate", RETURN_FALSE)
    RegisterPatch(state_mgr_direction.eva_state_mgr_direction, "evaluate", RETURN_FALSE)
    RegisterPatch(state_mgr_mental.eva_state_mgr_mental, "evaluate", RETURN_FALSE)
